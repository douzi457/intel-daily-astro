---
import '../styles/global.css';
interface Props {
  title: string;
  lang?: string;
}
const { title, lang = 'zh-CN' } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="AI-Powered Intelligence Hub. Real-time global insights, trends, and automated reporting." />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <slot />
</body>
</html>
