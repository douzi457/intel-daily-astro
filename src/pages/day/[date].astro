---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDayData, getAllDates } from '../../utils/data.ts';

export async function getStaticPaths() {
  const dates = getAllDates('zh');
  return dates.map(d => ({ params: { date: d } }));
}

const { date } = Astro.params as { date: string };
const dayData = getDayData(date, 'zh');
const totalItems = dayData.items.length;

const PLATFORM_META: Record<string, { label: string; icon: string; color: string }> = {
  weibo:           { label: '微博',     icon: '🔥', color: '#FF9500' },
  hackernews:      { label: 'HackerNews', icon: '⚡', color: '#FF6600' },
  github:          { label: 'GitHub',   icon: '🐙', color: '#6CCB5F' },
  producthunt:     { label: 'ProductHunt', icon: '🚀', color: '#DA5430' },
  v2ex:            { label: 'V2EX',     icon: '💬', color: '#4CAF50' },
  ithome:          { label: 'IT之家',   icon: '💻', color: '#0090D8' },
  '36kr':          { label: '36氪',     icon: '📊', color: '#4A90E2' },
  wallstreetcn:    { label: '华尔街见闻', icon: '📈', color: '#3395FF' },
  toutiao:         { label: '今日头条',  icon: '📰', color: '#E63946' },
  douyin:          { label: '抖音',     icon: '🎵', color: '#00F2EA' },
  news_aggregator: { label: '快讯聚合',  icon: '📌', color: '#94A3B8' },
};

const grouped: Record<string, any[]> = {};
for (const item of dayData.items) {
  const key = item.platform || 'other';
  if (!grouped[key]) grouped[key] = [];
  grouped[key].push(item);
}

const sortedAll = [...dayData.items].sort((a: any, b: any) => (b.score || 0) - (a.score || 0));
const featured = sortedAll.slice(0, 5);

const trending = [...dayData.items]
  .sort((a: any, b: any) => (b.hot || 0) - (a.hot || 0))
  .slice(0, 8);

const SECTION_ORDER = ['weibo', 'hackernews', 'github', 'producthunt', 'v2ex', 'ithome', '36kr', 'wallstreetcn', 'toutiao', 'douyin', 'news_aggregator'];
const SECTION_CATEGORIES: Record<string, { name: string; icon: string }> = {
  weibo:           { name: '微博热搜',  icon: '🔥' },
  hackernews:      { name: '开发者社区', icon: '💻' },
  github:          { name: '开源项目',  icon: '🐙' },
  producthunt:     { name: '新品发布',  icon: '🚀' },
  v2ex:            { name: 'V2EX 热议', icon: '💬' },
  ithome:          { name: '科技资讯',  icon: '💻' },
  '36kr':          { name: '商业快讯',  icon: '📊' },
  wallstreetcn:    { name: '财经洞察',  icon: '📈' },
  toutiao:         { name: '热点资讯',  icon: '📰' },
  douyin:          { name: '抖音热榜',  icon: '🎵' },
  news_aggregator: { name: '综合快讯',  icon: '📌' },
};

const FULL_WIDTH_SECTIONS = new Set(['news_aggregator']);

const activePlatforms = SECTION_ORDER.filter(p => grouped[p]?.length > 0);
const maxPlatformCount = Math.max(...activePlatforms.map(p => grouped[p].length), 1);

const NAV_TABS = [
  { id: 'featured', label: '精选', icon: '⭐' },
  ...activePlatforms.map(p => ({
    id: `platform-${p}`,
    label: SECTION_CATEGORIES[p]?.name || p,
    icon: SECTION_CATEGORIES[p]?.icon || '📌',
  })),
];

const allDates = getAllDates('zh');
const idx = allDates.indexOf(date);
const prevDay = idx < allDates.length - 1 ? allDates[idx + 1] : null;
const nextDay = idx > 0 ? allDates[idx - 1] : null;

const recentDates = allDates.slice(0, 12);

const dowLabels = ['周一','周二','周三','周四','周五','周六','周日'];
function getDow(d: string) {
  const ndx = new Date(d + 'T00:00:00').getDay();
  return dowLabels[ndx === 0 ? 6 : ndx - 1];
}
---

<BaseLayout title={`📡 ${date} 情报日报 · 豆子实验室`} lang="zh-CN">
<div class="page">

  <!-- Header -->
  <header class="header">
    <div class="header-brand">
      <div class="header-logo">豆子实验室<span>.每日情报</span></div>
      <span style="font-size:0.8em;color:var(--text-m);font-weight:500;margin-left:6px;">日报 · {date}</span>
    </div>
    <div class="header-meta">
      <span class="count-badge">{totalItems} 条情报</span>
      <a href="https://www.aliyun.com/minisite/goods?userCode=za8gqbw7" target="_blank" rel="noopener" class="badge-link">☁️ 阿里云 1折起</a>
    </div>
    <div class="header-actions">
      <a href="/" class="lang-btn">← 返回首页</a>
      <button id="themeToggle" class="theme-btn" aria-label="切换主题">🌙</button>
    </div>
  </header>

  <!-- Day Navigation -->
  <div style="display:flex;align-items:center;justify-content:center;gap:16px;margin-bottom:24px;">
    {prevDay ? <a href={`/day/${prevDay}`} style="font-size:0.85em;color:var(--text-m);padding:6px 14px;border:1px solid var(--border);border-radius:8px;font-weight:600;">← {prevDay}</a> : <span style="width:90px"></span>}
    <span style="font-size:0.9em;font-weight:700;color:var(--text-h);font-family:var(--font-mono);">{date} {getDow(date)}</span>
    {nextDay ? <a href={`/day/${nextDay}`} style="font-size:0.85em;color:var(--text-m);padding:6px 14px;border:1px solid var(--border);border-radius:8px;font-weight:600;">{nextDay} →</a> : <span style="width:90px"></span>}
  </div>

  <!-- Header thin banner -->
  {totalItems > 0 && (
    <div class="header-ad" id="headerAd">
      <a id="headerAdLink" href="https://cloud.tencent.com/act/cps/redirect?redirect=6544&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console" target="_blank" rel="noopener">
        <img id="headerAdImg" src="/assets/ads/tencent/banner/return_970_90.png" alt="腾讯云推广" loading="lazy">
      </a>
    </div>
  )}

</div>

<!-- Section Nav -->
<div class="section-nav-wrap">
  <nav class="section-nav" id="sectionNav">
    {NAV_TABS.map(tab => (
      <a href={`#${tab.id}`} data-target={tab.id} class={tab.id === 'featured' ? 'active' : ''}>
        {tab.icon} {tab.label}
      </a>
    ))}
  </nav>
</div>

<div class="page">

  <!-- Content Grid -->
  <div class="content-grid">
    <div class="main-content">

      <!-- Featured Bento -->
      <section id="featured" class="featured-bento">
        {featured.length > 0 && (
          <>
            <div class="featured-hero">
              {featured.slice(0, 3).map((item, idx) => {
                const meta = PLATFORM_META[item.platform] || { label: item.platform_label || item.platform, icon: '📌', color: '#94A3B8' };
                return (
                  <div class="hero-entry">
                    <div class="hero-entry-rank">{idx === 0 ? '★ 精选头条' : `#${idx + 1} 精选`}</div>
                    <div class="hero-entry-title"><a href={item.url} target="_blank" rel="noopener">{item.title}</a></div>
                    <div class="hero-entry-meta">
                      <span class="platform-tag" style={`color:${meta.color};border-color:${meta.color}20;background:${meta.color}10`}>
                        <span class="tag-icon">{meta.icon}</span>
                        {meta.label}
                      </span>
                      {item.score > 0 && <span class={`signal-badge ${item.score >= 8 ? 'high' : item.score >= 6 ? 'med' : ''}`}>信号 {item.score}</span>}
                    </div>
                  </div>
                );
              })}
            </div>

            {featured.length > 3 && (
              <div class="featured-side">
                {featured.slice(3).map((item, idx) => {
                  const meta = PLATFORM_META[item.platform] || { label: item.platform_label || item.platform, icon: '📌', color: '#94A3B8' };
                  return (
                    <div class="featured-mini">
                      <span class="mini-rank">#{idx + 4} 推荐</span>
                      <a href={item.url} target="_blank" rel="noopener" class="mini-title">{item.title}</a>
                      <span class="platform-tag" style={`color:${meta.color};border-color:${meta.color}20;background:${meta.color}10`}>
                        <span class="tag-icon">{meta.icon}</span>
                        {meta.label}
                      </span>
                      {item.score > 0 && <span class={`signal-badge ${item.score >= 8 ? 'high' : item.score >= 6 ? 'med' : ''}`}>信号 {item.score}</span>}
                    </div>
                  );
                })}
              </div>
            )}
          </>
        )}
      </section>

      <!-- Platform Grid -->
      <div class="platform-grid">
        {activePlatforms.map(platform => {
          const items = grouped[platform];
          const cat = SECTION_CATEGORIES[platform] || { name: platform, icon: '📌' };
          const meta = PLATFORM_META[platform] || { label: platform, icon: '📌', color: '#94A3B8' };
          const isFullWidth = FULL_WIDTH_SECTIONS.has(platform);

          return (
            <section class={`platform-section ${isFullWidth ? 'section-full' : ''}`} id={`platform-${platform}`}>
              <div class="section-header">
                <div class="section-title">
                  <span>{cat.icon}</span>
                  <span>{cat.name}</span>
                  <span class="section-count">{items.length}</span>
                </div>
              </div>
              <div class="news-list">
                {items.map((item: any, idx: number) => {
                  const hotValue = item.hot || 0;
                  return (
                    <div class={`news-item ${item.score >= 7 ? 'score-high' : item.score >= 5 ? 'score-med' : ''}`}>
                      <span class="news-idx">{idx + 1}</span>
                      <div class="news-body">
                        <a href={item.url} target="_blank" rel="noopener" class="news-title">{item.title}</a>
                        <div class="news-footer">
                          <span class="platform-tag" style={`color:${meta.color};border-color:${meta.color}20;background:${meta.color}10`}>
                            <span class="tag-icon">{meta.icon}</span>
                            {meta.label}
                          </span>
                          {hotValue > 0 && <span class="news-hot">🔥 {hotValue}</span>}
                          {item.score > 0 && <span class="news-score">信号 <strong>{item.score}</strong></span>}
                        </div>
                        {item.desc && <div class="news-desc">{item.desc}</div>}
                      </div>
                    </div>
                  );
                })}
              </div>
            </section>
          );
        })}
      </div>

      <!-- Native feed-style ad -->
      {totalItems > 0 && (
        <div class="section" style="margin-bottom:0;">
          <div class="section-header">
            <div class="section-title" style="font-size:0.9em;">💡 推荐</div>
          </div>
          <div class="news-list">
            <div class="news-item">
              <span class="news-idx" style="color:var(--accent);">💡</span>
              <div class="news-body">
                <a href="https://cloud.tencent.com/act/cps/redirect?redirect=6544&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console" target="_blank" rel="noopener" class="news-title">腾讯云 AI 焕新季 · 2核2G4M 新客仅 99元/年</a>
                <div class="news-footer">
                  <span class="platform-tag" style="color:#3395FF;border-color:#3395FF20;background:#3395FF10;">☁️ 腾讯云</span>
                  <span class="news-hot" style="color:var(--accent);">推广</span>
                </div>
                <div class="news-desc">轻量应用服务器 4核4G3M 首年 79元，限时特惠中</div>
              </div>
            </div>
          </div>
        </div>
      )}

      <!-- Native Ad: 腾讯云（自动轮换） -->
      {totalItems > 0 && (
        <div id="tencentAd" class="ad-card-img" style="display:block;text-decoration:none;">
          <a id="tencentAdLink" href="https://cloud.tencent.com/act/cps/redirect?redirect=6544&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console" target="_blank" rel="noopener">
            <img id="tencentAdImg" src="/assets/ads/tencent/banner/ai_banner.png" alt="腾讯云推广" loading="lazy" style="width:100%;height:auto;border-radius:12px;display:block;">
          </a>
        </div>
      )}

      <!-- History -->
      {recentDates.length > 0 && (
        <section class="section section-full">
          <div class="section-header">
            <div class="section-title">📅 其他日期</div>
          </div>
          <div class="history-grid">
            {recentDates.filter(d => d !== date).map(d => (
              <a href={`/day/${d}`} class="history-item">
                <div>{d}</div>
                <div class="dow">{getDow(d)}</div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>

    <!-- Sidebar -->
    <aside class="sidebar">

      <!-- Platform Distribution -->
      {activePlatforms.length > 0 && (
        <div class="sidebar-widget">
          <div class="sidebar-widget-title">📊 平台分布</div>
          {activePlatforms.map(p => {
            const cnt = grouped[p].length;
            const meta = PLATFORM_META[p] || { label: p, icon: '📌', color: '#94A3B8' };
            const pct = Math.round(cnt / maxPlatformCount * 100);
            return (
              <div class="dist-item">
                <div class="dist-header">
                  <span class="dist-label">{meta.icon} {meta.label}</span>
                  <span class="dist-count">{cnt}</span>
                </div>
                <div class="dist-bar">
                  <div class="dist-bar-fill" style={`width:${pct}%;background:${meta.color}`}></div>
                </div>
              </div>
            );
          })}
        </div>
      )}

      <!-- Mini Stats -->
      <div class="sidebar-widget">
        <div class="sidebar-widget-title">📊 数据概览</div>
        <div class="stats-grid">
          <div class="stat-cell">
            <div class="stat-cell-value">{totalItems}</div>
            <div class="stat-cell-label">当日情报</div>
          </div>
          <div class="stat-cell">
            <div class="stat-cell-value">{activePlatforms.length}</div>
            <div class="stat-cell-label">数据源</div>
          </div>
          <div class="stat-cell">
            <div class="stat-cell-value">{recentDates.length}</div>
            <div class="stat-cell-label">覆盖天数</div>
          </div>
          <div class="stat-cell">
            <div class="stat-cell-value">{dayData.items.filter((i: any) => i.score >= 7).length}</div>
            <div class="stat-cell-label">高价值信号</div>
          </div>
        </div>
      </div>

      <!-- 腾讯云推广（侧边栏） -->
      <a href="https://cloud.tencent.com/act/cps/redirect?redirect=1079&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console" target="_blank" rel="noopener" class="sidebar-widget" style="padding:0;overflow:hidden;border-radius:14px;display:block;">
        <img src="/assets/ads/tencent/sidebar/return_300_250.png" alt="腾讯云 · 轻量服务器 4核4G3M 仅 79元/年" loading="lazy" style="width:100%;height:auto;display:block;">
      </a>

      <!-- 公众号关注 -->
      <div class="sidebar-widget">
        <div class="sidebar-widget-title">📢 豆子实验室</div>
        <div style="text-align:center;padding:4px 0;">
          <div style="font-size:0.82em;font-weight:600;color:var(--text-h);margin-bottom:8px;">每日情报 · 技术干货</div>
          <div style="background:var(--bg);border-radius:8px;padding:12px;margin-bottom:10px;font-size:0.72em;color:var(--text-m);line-height:1.6;">
            📱 微信搜索 <strong style="color:var(--accent);">「豆子实验室」</strong><br />
            或扫码关注，获取每日推送
          </div>
          <div style="width:120px;height:120px;margin:0 auto 8px;background:var(--bg);border-radius:8px;border:1px dashed var(--border);display:flex;align-items:center;justify-content:center;font-size:0.65em;color:var(--text-m);">
            <span>QR 码<br/>（替换为你的二维码）</span>
          </div>
          <div style="font-size:0.65em;color:var(--accent);font-weight:600;">→ 去关注</div>
        </div>
      </div>

      <!-- 资源福利 -->
      <div class="sidebar-widget">
        <div class="sidebar-widget-title">🎁 资源福利</div>
        <div style="display:flex;flex-direction:column;gap:6px;">
          <a href="#" target="_blank" rel="noopener" style="font-size:0.78em;padding:8px 10px;background:var(--bg);border-radius:6px;color:var(--text-p);display:flex;align-items:center;gap:8px;">
            <span>🤖</span>
            <span>AI 工具合集</span>
            <span style="margin-left:auto;font-size:0.75em;color:var(--text-m);">→</span>
          </a>
          <a href="#" target="_blank" rel="noopener" style="font-size:0.78em;padding:8px 10px;background:var(--bg);border-radius:6px;color:var(--text-p);display:flex;align-items:center;gap:8px;">
            <span>📚</span>
            <span>编程学习资料</span>
            <span style="margin-left:auto;font-size:0.75em;color:var(--text-m);">→</span>
          </a>
          <a href="#" target="_blank" rel="noopener" style="font-size:0.78em;padding:8px 10px;background:var(--bg);border-radius:6px;color:var(--text-p);display:flex;align-items:center;gap:8px;">
            <span>📡</span>
            <span>情报汇总 PDF</span>
            <span style="margin-left:auto;font-size:0.75em;color:var(--text-m);">→</span>
          </a>
        </div>
      </div>

      <!-- Trending / Top Signals -->
      <div class="sidebar-widget">
        {trending.filter((i: any) => i.hot > 0).length > 0 ? (
          <>
            <div class="sidebar-widget-title">🔥 实时热度</div>
            {trending.map((item, idx) => (
              <div class="trending-item">
                <span class={`trending-rank ${idx < 3 ? 'top-3' : ''}`}>{idx + 1}</span>
                <a href={item.url} target="_blank" rel="noopener" class="trending-title">{item.title}</a>
              </div>
            ))}
          </>
        ) : (
          <>
            <div class="sidebar-widget-title">📡 高分信号</div>
            {featured.map((item, idx) => {
              const meta = PLATFORM_META[item.platform] || { label: item.platform_label || item.platform, icon: '📌', color: '#94A3B8' };
              return (
                <div class="signal-item">
                  <span class={`signal-badge ${item.score >= 8 ? 'high' : 'med'}`}>{item.score}</span>
                  <div>
                    <span class="signal-source" style={`color:${meta.color}`}>{meta.icon} {meta.label}</span>
                    <a href={item.url} target="_blank" rel="noopener" class="signal-title">{item.title}</a>
                  </div>
                </div>
              );
            })}
          </>
        )}
      </div>

    </aside>
  </div>

  <div class="footer">
    📡 智谱 GLM-5 驱动 · 豆子实验室 每日情报<br />
    每日自动采集 · AI 智能评分 · 原生广告展示
  </div>

</div>

<button id="backToTop" class="back-to-top" aria-label="回到顶部">↑</button>

</BaseLayout>

<style>
  html { scroll-behavior: smooth; }

  .featured-hero {
    display: flex;
    flex-direction: column;
    padding: 16px 20px;
  }
  .hero-entry {
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
  }
  .hero-entry:last-child {
    border-bottom: none;
  }
  .hero-entry-rank {
    font-family: var(--font-mono);
    font-size: 0.6em;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 4px;
    letter-spacing: 0.5px;
  }
  .hero-entry-title {
    font-size: 0.88em;
    font-weight: 700;
    color: var(--text-h);
    line-height: 1.4;
    margin-bottom: 6px;
  }
  .hero-entry-title a:hover {
    color: var(--accent);
  }
  .hero-entry-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
  }
</style>

<script>
  const themeBtn = document.getElementById('themeToggle');
  if (themeBtn) {
    let theme = localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-theme', theme);
    themeBtn.textContent = theme === 'dark' ? '☀️' : '🌙';
    themeBtn.addEventListener('click', () => {
      theme = theme === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
      themeBtn.textContent = theme === 'dark' ? '☀️' : '🌙';
    });
  }

  const nav = document.getElementById('sectionNav');
  if (nav) {
    const links = nav.querySelectorAll('a');
    const sections = Array.from(links).map(link => {
      const id = link.getAttribute('data-target');
      return id ? document.getElementById(id) : null;
    }).filter(Boolean);

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          links.forEach(link => {
            link.classList.toggle('active', link.getAttribute('data-target') === id);
          });
        }
      });
    }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });

    sections.forEach(section => {
      if (section) observer.observe(section);
    });
  }

  const backBtn = document.getElementById('backToTop');
  if (backBtn) {
    window.addEventListener('scroll', () => {
      backBtn.classList.toggle('visible', window.scrollY > 400);
    });
    backBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  // Tencent Cloud banner rotation (main)
  const adImg = document.getElementById('tencentAdImg');
  const adLink = document.getElementById('tencentAdLink');
  if (adImg && adLink) {
    const promos = [
      { src: '/assets/ads/tencent/banner/ai_banner.png', href: 'https://cloud.tencent.com/act/cps/redirect?redirect=6544&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console', alt: '腾讯云 AI焕新季 · 2核2G4M 新客 99元/年' },
      { src: '/assets/ads/tencent/banner/lighthouse_480_300.png', href: 'https://cloud.tencent.com/act/cps/redirect?redirect=1079&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console', alt: '腾讯云 · 轻量服务器 4核4G3M 仅 79元/年' },
