---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { TABS, TAB_COLORS, TAB_ICONS, getDayData, getAllDates } from '../../utils/data.ts';

export async function getStaticPaths() {
  const dates = getAllDates('zh');
  return dates.map(d => ({ params: { date: d } }));
}

const { date } = Astro.params as { date: string };
const dayData = getDayData(date, 'zh');

// 统计
const tabCounts: Record<string, number> = {};
TABS.forEach(t => tabCounts[t] = 0);
dayData.items.forEach((it: any) => {
  tabCounts[it.tab || '财经'] = (tabCounts[it.tab || '财经'] || 0) + 1;
});

// 前后日期导航
const dates = getAllDates('zh');
const idx = dates.indexOf(date);
const prevDay = idx < dates.length - 1 ? dates[idx + 1] : null;
const nextDay = idx > 0 ? dates[idx - 1] : null;
---

<BaseLayout title={`📡 ${date} 情报日报 · INTEL.SYS`}>
<div class="layout">

  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-text">INTEL<span>.SYS</span></div>
      <div class="logo-sub">Superpowers · 情报站</div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section">
        <div class="nav-section-title">导航</div>
        <a href="/" class="nav-item"><span class="icon">📡</span><span class="label">首页</span></a>
        <a href={`/day/${date}`} class="nav-item active"><span class="icon">📈</span><span class="label">今日日报</span></a>
        <a href="/archive" class="nav-item"><span class="icon">📁</span><span class="label">归档</span></a>
        <a href="/stats" class="nav-item"><span class="icon">📊</span><span class="label">统计</span></a>
      </div>
      <div class="nav-section">
        <div class="nav-section-title">最近日报</div>
        {dates.slice(0, 8).map(d => (
          <a href={`/day/${d}`} class="nav-item-recent">
            <span>{d}</span>
          </a>
        ))}
      </div>
    </nav>
    <div class="sidebar-footer">自动生成 · 每2小时更新</div>
  </aside>

  <main class="main">
    <div class="container">

      <div class="topbar">
        <h1 class="topbar-title">📡 <span>{date}</span> 情报日报</h1>
        <span class="topbar-meta">{dayData.items.length} 条内容</span>
      </div>

      <!-- 导航 -->
      <div class="day-nav">
        {prevDay
          ? <a href={`/day/${prevDay}`}>←</a>
          : <span style="width:38px;display:inline-block"></span>}
        <span class="current">{date}</span>
        {nextDay
          ? <a href={`/day/${nextDay}`}>→</a>
          : <span style="width:38px;display:inline-block"></span>}
      </div>

      <!-- Tab 统计 -->
      <div class="stats-grid">
        <div class="stat-card" style="--accent-color: var(--amber)">
          <div class="sc-icon">📡</div><div class="sc-num">{dayData.items.length}</div><div class="sc-lbl">总计</div>
        </div>
        {TABS.map(tab => (
          <div class="stat-card" style={`--accent-color: ${TAB_COLORS[tab]}`}>
            <div class="sc-icon">{TAB_ICONS[tab]}</div>
            <div class="sc-num">{tabCounts[tab] || 0}</div>
            <div class="sc-lbl">{tab}</div>
          </div>
        ))}
      </div>

      <!-- Tab 筛选 -->
      <div class="tab-filter">
        <button class="tab-btn active" data-tab="全部">📡 全部<span class="cnt">{dayData.items.length}</span></button>
        {TABS.map(tab => (
          <button class="tab-btn" data-tab={tab}>{TAB_ICONS[tab]} {tab}<span class="cnt">{tabCounts[tab] || 0}</span></button>
        ))}
      </div>
      <div class="search-wrap">
        <input class="search-input" id="q" placeholder="🔍 搜索标题/描述..." autocomplete="off"/>
        <span class="result-hint" id="cntHint"></span>
      </div>

      <!-- 内容列表 -->
      <div class="item-list" id="itemList">
        {dayData.items.map((it: any, idx: number) => (
          <div class="item-card" data-tab={it.tab} style={`--item-color: ${it.platform_color}`}>
            <div class="item-idx">{idx + 1}</div>
            <div class="item-badge"
                 style={`--badge-bg: ${it.platform_color}22; --badge-color: ${it.platform_color}`}>
              {it.platform_icon} {it.platform_label}
            </div>
            <div class="item-body">
              <div class="item-title"><a href={it.url} target="_blank">{it.title}</a></div>
              <div class="item-desc">{it.desc}</div>
              <div class="item-meta">
                {it.hot_stars > 0 && <span class="item-hot">{'🔥'.repeat(it.hot_stars)}</span>}
                <span class="item-time">{it.date}</span>
              </div>
            </div>
          </div>
        ))}
      </div>

      <footer>📡 INTEL.SYS · {date}</footer>
    </div>
  </main>

</div>

<script>
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const tab = (btn as HTMLElement).dataset.tab!;
      document.querySelectorAll('.item-card').forEach(card => {
        (card as HTMLElement).classList.toggle('hidden',
          tab !== '全部' && (card as HTMLElement).dataset.tab !== tab);
      });
      updateCount();
    });
  });

  const q = document.getElementById('q') as HTMLInputElement;
  if (q) {
    q.addEventListener('input', () => {
      const v = q.value.toLowerCase().trim();
      document.querySelectorAll('.item-card').forEach(card => {
        (card as HTMLElement).classList.toggle('hidden',
          v !== '' && !(card as HTMLElement).textContent!.toLowerCase().includes(v));
      });
      updateCount();
    });
  }

  function updateCount() {
    const hint = document.getElementById('cntHint');
    if (!hint) return;
    const visible = document.querySelectorAll('.item-card:not(.hidden)').length;
    hint.textContent = `${visible} 条`;
  }
  updateCount();
</script>
</BaseLayout>
