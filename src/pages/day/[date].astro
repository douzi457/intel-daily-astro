---
// 日报页 — 使用共享组件
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FocusSection from '../../components/FocusSection.astro';
import FeaturedSection from '../../components/FeaturedSection.astro';
import PlatformSection from '../../components/PlatformSection.astro';
import Sidebar from '../../components/Sidebar.astro';
import SectionNav from '../../components/SectionNav.astro';
import CalendarWidget from '../../components/CalendarWidget.astro';
import { getDayData, getAllDates } from '../../utils/data.ts';
import { SITE, SECTION_ORDER, getDow } from '../../lib/constants';
import type { FocusData, IntelItem, GzhArticle } from '../../lib/types';
import articles from '../../data/gzh-articles.json';

// ── 静态路径生成 ──
export async function getStaticPaths() {
  const dates = getAllDates('zh');
  return dates.map(d => ({ params: { date: d } }));
}

// ── 数据加载 ──
let focusData: FocusData | null = null;
try {
  const mod = await import('../../data/rewrite/today-focus.json');
  focusData = mod.default as FocusData;
} catch {}

const filteredArticles: GzhArticle[] = articles.filter((a: GzhArticle) => a.title);

const { date } = Astro.params as { date: string };
const dayData = getDayData(date, 'zh');
const items: IntelItem[] = dayData.items;
const totalItems = items.length;

// ── 分组排序 ──
const grouped: Record<string, IntelItem[]> = {};
for (const item of items) {
  const key = item.platform || 'other';
  if (!grouped[key]) grouped[key] = [];
  grouped[key].push(item);
}

const sortedAll = [...items].sort((a, b) => (b.score || 0) - (a.score || 0));
const featured = sortedAll.slice(0, 5);

const trending = [...items]
  .sort((a, b) => (b.hot || 0) - (a.hot || 0))
  .slice(0, 10);

const activeSections = SECTION_ORDER.filter(s => (grouped[s]?.length || 0) > 0);
const highScoreCount = items.filter(i => i.score >= 7).length;

// ── 导航 ──
const allDates = getAllDates('zh');
const idx = allDates.indexOf(date);
const prevDay = idx < allDates.length - 1 ? allDates[idx + 1] : null;
const nextDay = idx > 0 ? allDates[idx - 1] : null;
const recentDates = allDates.slice(0, 12);

// 动态 meta description（用当天第一精选）
const metaDesc = featured.length > 0
  ? `${date} 情报日报 · ${featured[0].title}`
  : `${date} 情报日报 · ${SITE.name} 每日情报`;

const pageUrl = `${SITE.url}/day/${date}`;
const prevUrl = prevDay ? `${SITE.url}/day/${prevDay}` : '';
const nextUrl = nextDay ? `${SITE.url}/day/${nextDay}` : '';
---

<BaseLayout
  title={`📡 ${date} 情报日报 · ${SITE.name}`}
  lang="zh-CN"
  description={metaDesc}
  canonicalUrl={pageUrl}
  prevUrl={prevUrl}
  nextUrl={nextUrl}
>
<div class="page">
  <Header mode="day" date={date} totalItems={totalItems} />

  <!-- 日期导航 -->
  <div class="day-nav">
    {prevDay ? <a href={`/day/${prevDay}`} class="day-nav-link">← {prevDay}</a> : <span class="day-nav-spacer"></span>}
    <span class="day-nav-current">{date} {getDow(date, 'zh')}</span>
    {nextDay ? <a href={`/day/${nextDay}`} class="day-nav-link">{nextDay} →</a> : <span class="day-nav-spacer"></span>}
  </div>
</div>

<SectionNav activeSections={activeSections} locale="zh" />

<div class="page">
  <!-- 今日重点（仅当日匹配时显示） -->
  {focusData && focusData.date === date && (
    <FocusSection focusData={focusData} today={date} />
  )}

  <div class="content-grid">
    <div class="main-content">
      <PlatformSection grouped={grouped} locale="zh" />
      <FeaturedSection featured={featured} locale="zh" />

      <!-- 原生推广卡片 -->
      {totalItems > 0 && (
        <div class="section" style="margin-bottom:0;">
          <div class="section-header">
            <div class="section-title" style="font-size:0.9em;">💡 推荐</div>
          </div>
          <div class="news-list">
            <div class="news-item" style="--tag-color:#3395FF">
              <span class="news-idx" style="color:var(--accent);">💡</span>
              <div class="news-body">
                <a href="https://cloud.tencent.com/act/cps/redirect?redirect=6544&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console" target="_blank" rel="noopener" class="news-title">腾讯云 AI 焕新季 · 2核2G4M 新客仅 99元/年</a>
                <div class="news-footer">
                  <span class="platform-tag" style="--tag-color:#3395FF">☁️ 腾讯云</span>
                  <span class="news-hot" style="color:var(--accent);">推广</span>
                </div>
                <div class="news-desc">轻量应用服务器 4核4G3M 首年 79元，限时特惠中</div>
              </div>
            </div>
          </div>
        </div>
      )}

      <!-- 日历 -->
      {allDates.length > 0 && (
        <section class="section section-full">
          <CalendarWidget dates={allDates} basePath="/day/" locale="zh" currentDate={date} />
        </section>
      )}
    </div>

    <!-- 侧边栏 -->
    <Sidebar
      totalItems={totalItems}
      activeSectionCount={activeSections.length}
      coverageDays={recentDates.length}
      highScoreCount={highScoreCount}
      grouped={grouped}
      featured={featured}
      trending={trending}
      filteredArticles={filteredArticles}
      locale="zh"
    />
  </div>

  <Footer />
</div>

<button id="backToTop" class="back-to-top" aria-label="回到顶部">↑</button>
</BaseLayout>

<style>
html { scroll-behavior: smooth; }

.content-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 28px;
}

@media (min-width: 1024px) {
  .content-grid { grid-template-columns: 1fr 300px; }
}

.main-content {
  display: flex;
  flex-direction: column;
  gap: 28px;
  min-width: 0;
}

.day-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  margin-bottom: 24px;
}

.day-nav-link {
  font-size: 0.85em;
  color: var(--text-m);
  padding: 6px 14px;
  border: 1px solid var(--border);
  border-radius: 8px;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.15s;
}

.day-nav-link:hover { border-color: var(--accent); color: var(--accent); }

.day-nav-current {
  font-size: 0.9em;
  font-weight: 700;
  color: var(--text-h);
  font-family: var(--font-mono);
}

.day-nav-spacer { width: 90px; }

.back-to-top {
  position: fixed;
  bottom: 32px;
  right: 32px;
  width: 44px;
  height: 44px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: var(--bg-card);
  color: var(--text-m);
  font-size: 1.2em;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: translateY(10px);
  transition: all 0.2s;
  z-index: 200;
  box-shadow: var(--shadow-md);
}

.back-to-top.visible { opacity: 1; transform: translateY(0); }
.back-to-top:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }

@media (max-width: 768px) {
  .back-to-top { bottom: 20px; right: 20px; width: 40px; height: 40px; }
  .day-nav-spacer { width: 50px; }
}
</style>

<script>
  const nav = document.getElementById('sectionNav');
  if (nav) {
    const links = nav.querySelectorAll('a[data-target]');
    const sections = Array.from(links).map(link => {
      const id = link.getAttribute('data-target');
      return id ? document.getElementById(id) : null;
    }).filter(Boolean) as HTMLElement[];

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          links.forEach(link => {
            link.classList.toggle('active', link.getAttribute('data-target') === id);
          });
        }
      });
    }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });

    sections.forEach(section => observer.observe(section));
  }

  const backBtn = document.getElementById('backToTop');
  if (backBtn) {
    window.addEventListener('scroll', () => {
      backBtn.classList.toggle('visible', window.scrollY > 400);
    });
    backBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  }

  const promoEl = document.getElementById('tencentPromo') as HTMLAnchorElement | null;
  if (promoEl) {
    const promos = [
      { text: '💙 轻量服务器 4核4G3M 79元/年', href: 'https://cloud.tencent.com/act/cps/redirect?redirect=1079&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console' },
      { text: '🤖 AI焕新季 2核2G4M 99元/年', href: 'https://cloud.tencent.com/act/cps/redirect?redirect=6544&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console' },
      { text: '🎁 推广大使特惠合集', href: 'https://cloud.tencent.com/act/cps/redirect?redirect=2446&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console' },
    ];
    let pi = 0;
    setInterval(() => {
      pi = (pi + 1) % promos.length;
      const p = promos[pi];
      promoEl.textContent = p.text;
      promoEl.href = p.href;
    }, 8000);
  }
</script>
