---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDayData, getAllDates } from '../../utils/data.ts';

export async function getStaticPaths() {
  const dates = getAllDates('zh');
  return dates.map(d => ({ params: { date: d } }));
}

const { date } = Astro.params as { date: string };
const dayData = getDayData(date, 'zh');
const totalItems = dayData.items.length;
const recentDates = getAllDates('zh').slice(0, 12);

const PLATFORM_META: Record<string, { label: string; icon: string; color: string }> = {
  weibo:           { label: '微博',     icon: '🔥', color: '#FF9500' },
  hackernews:      { label: 'HackerNews', icon: '⚡', color: '#FF6600' },
  github:          { label: 'GitHub',   icon: '🐙', color: '#6CCB5F' },
  producthunt:     { label: 'ProductHunt', icon: '🚀', color: '#DA5430' },
  v2ex:            { label: 'V2EX',     icon: '💬', color: '#4CAF50' },
  ithome:          { label: 'IT之家',   icon: '💻', color: '#0090D8' },
  '36kr':          { label: '36氪',     icon: '📊', color: '#4A90E2' },
  wallstreetcn:    { label: '华尔街见闻', icon: '📈', color: '#3395FF' },
  toutiao:         { label: '今日头条',  icon: '📰', color: '#E63946' },
  douyin:          { label: '抖音',     icon: '🎵', color: '#00F2EA' },
  news_aggregator: { label: '快讯聚合',  icon: '📌', color: '#94A3B8' },
};

const grouped: Record<string, any[]> = {};
for (const item of dayData.items) {
  const key = item.platform || 'other';
  if (!grouped[key]) grouped[key] = [];
  grouped[key].push(item);
}

const sortedAll = [...dayData.items].sort((a: any, b: any) => (b.score || 0) - (a.score || 0));
const featured = sortedAll.slice(0, 5);

const SECTION_ORDER = ['weibo', 'hackernews', 'github', 'producthunt', 'v2ex', 'ithome', '36kr', 'wallstreetcn', 'toutiao', 'douyin', 'news_aggregator'];
const SECTION_CATEGORIES: Record<string, { name: string; icon: string }> = {
  weibo:           { name: '微博热搜',  icon: '🔥' },
  hackernews:      { name: '开发者社区', icon: '💻' },
  github:          { name: '开源项目',  icon: '🐙' },
  producthunt:     { name: '新品发布',  icon: '🚀' },
  v2ex:            { name: 'V2EX 热议', icon: '💬' },
  ithome:          { name: '科技资讯',  icon: '💻' },
  '36kr':          { name: '商业快讯',  icon: '📊' },
  wallstreetcn:    { name: '财经洞察',  icon: '📈' },
  toutiao:         { name: '热点资讯',  icon: '📰' },
  douyin:          { name: '抖音热榜',  icon: '🎵' },
  news_aggregator: { name: '综合快讯',  icon: '📌' },
};

const FULL_WIDTH_SECTIONS = new Set(['weibo', 'douyin', 'news_aggregator']);

const dowLabels = ['周一','周二','周三','周四','周五','周六','周日'];
function getDow(d: string) {
  const idx = new Date(d + 'T00:00:00').getDay();
  return dowLabels[idx === 0 ? 6 : idx - 1];
}
---

<BaseLayout title={`📡 ${date} 情报日报 · INTEL.SYS`} lang="zh-CN">
<div class="page">

  <!-- Header -->
  <header class="header">
    <div class="header-brand">
      <div class="header-logo">INTEL<span>.SYS</span></div>
      <span style="font-size:0.8em;color:var(--text-m);font-weight:500;margin-left:6px;">日报 · {date}</span>
    </div>
    <div class="header-meta">
      <span class="count-badge">{totalItems} 条情报</span>
    </div>
    <div class="header-actions">
      <a href="/" class="lang-btn">← 返回首页</a>
      <button id="themeToggle" class="theme-btn" aria-label="切换主题">🌙</button>
    </div>
  </header>

  <!-- Featured Picks -->
  {featured.length > 0 && (
    <section class="featured">
      {featured.map((item, idx) => {
        const meta = PLATFORM_META[item.platform] || { label: item.platform_label || item.platform, icon: '📌', color: '#94A3B8' };
        return (
          <div class="featured-card">
            <div class="featured-rank">{idx === 0 ? '★ 精选头条' : `#${idx + 1} 推荐`}</div>
            <div class="featured-title"><a href={item.url} target="_blank" rel="noopener">{item.title}</a></div>
            <div class="featured-meta">
              <span class="platform-tag" style={`color:${meta.color};border-color:${meta.color}20;background:${meta.color}10`}>
                <span class="tag-icon">{meta.icon}</span>
                {meta.label}
              </span>
              {item.score > 0 && <span class="featured-signal">信号 {item.score}</span>}
            </div>
            {item.desc && <div class="featured-desc">{item.desc}</div>}
          </div>
        );
      })}
    </section>
  )}

  <!-- Platform Sections -->
  <div class="platform-grid">
    {SECTION_ORDER.filter(p => grouped[p]?.length > 0).map(platform => {
      const items = grouped[platform];
      const cat = SECTION_CATEGORIES[platform] || { name: platform, icon: '📌' };
      const meta = PLATFORM_META[platform] || { label: platform, icon: '📌', color: '#94A3B8' };
      const isFullWidth = FULL_WIDTH_SECTIONS.has(platform);

      return (
        <section class={`platform-section ${isFullWidth ? 'section-full' : ''}`} id={`platform-${platform}`}>
          <div class="section-header">
            <div class="section-title">
              <span>{cat.icon}</span>
              <span>{cat.name}</span>
              <span class="section-count">{items.length}</span>
            </div>
          </div>
          <div class="news-list">
            {items.map((item: any, idx: number) => {
              const hotValue = item.hot || 0;
              return (
                <div class="news-item">
                  <span class="news-idx">{idx + 1}</span>
                  <div class="news-body">
                    <a href={item.url} target="_blank" rel="noopener" class="news-title">{item.title}</a>
                    <div class="news-footer">
                      <span class="platform-tag" style={`color:${meta.color};border-color:${meta.color}20;background:${meta.color}10`}>
                        <span class="tag-icon">{meta.icon}</span>
                        {meta.label}
                      </span>
                      {hotValue > 0 && <span class="news-hot">🔥 {hotValue}</span>}
                      {item.score > 0 && <span class="news-score">信号 {item.score}</span>}
                    </div>
                    {item.desc && <div class="news-desc">{item.desc}</div>}
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      );
    })}
  </div>

  <!-- History -->
  {recentDates.length > 0 && (
    <section class="section">
      <div class="section-header">
        <div class="section-title">📅 其他日期</div>
      </div>
      <div class="history-grid">
        {recentDates.map(d => (
          <a href={`/day/${d}`} class="history-item">
            <div>{d}</div>
            <div class="dow">{getDow(d)}</div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Footer -->
  <div class="footer">📡 INTEL.SYS · {date} 情报日报</div>

</div>

<style>
  html { scroll-behavior: smooth; }
</style>

<script>
  const themeBtn = document.getElementById('themeToggle');
  if (themeBtn) {
    let theme = localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-theme', theme);
    themeBtn.textContent = theme === 'dark' ? '☀️' : '🌙';
    themeBtn.addEventListener('click', () => {
      theme = theme === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
      themeBtn.textContent = theme === 'dark' ? '☀️' : '🌙';
    });
  }
</script>
</BaseLayout>
