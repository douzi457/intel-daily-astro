---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDayData, getAllDates } from '../../utils/data.ts';
import CalendarWidget from '../../components/CalendarWidget.astro';
import articles from '../../data/gzh-articles.json';

let focusData: any = null;
try {
  const mod = await import('../../data/rewrite/today-focus.json');
  focusData = mod.default;
} catch {}

const filteredArticles = articles.filter(a => a.title);

export async function getStaticPaths() {
  const dates = getAllDates('zh');
  return dates.map(d => ({ params: { date: d } }));
}

const { date } = Astro.params as { date: string };
const dayData = getDayData(date, 'zh');
const totalItems = dayData.items.length;

const PLATFORM_META: Record<string, { label: string; icon: string; color: string }> = {
  weibo:           { label: '微博',     icon: '🔥', color: '#FF9500' },
  hackernews:      { label: 'HackerNews', icon: '⚡', color: '#FF6600' },
  github:          { label: 'GitHub',   icon: '🐙', color: '#6CCB5F' },
  producthunt:     { label: 'ProductHunt', icon: '🚀', color: '#DA5430' },
  v2ex:            { label: 'V2EX',     icon: '💬', color: '#4CAF50' },
  ithome:          { label: 'IT之家',   icon: '💻', color: '#0090D8' },
  '36kr':          { label: '36氪',     icon: '📊', color: '#4A90E2' },
  wallstreetcn:    { label: '华尔街见闻', icon: '📈', color: '#3395FF' },
  toutiao:         { label: '今日头条',  icon: '📰', color: '#E63946' },
  douyin:          { label: '抖音',     icon: '🎵', color: '#00F2EA' },
  news_aggregator: { label: '快讯聚合',  icon: '📌', color: '#94A3B8' },
  bilibili:        { label: 'B站',      icon: '📺', color: '#FB7299' },
  zhihu:           { label: '知乎',     icon: '💡', color: '#0066FF' },
  baidu:           { label: '百度热搜', icon: '🔍', color: '#2932E1' },
  tieba:           { label: '百度贴吧', icon: '📋', color: '#4B90E0' },
  cailianshe:      { label: '财联社',   icon: '📡', color: '#C71A1A' },
  pengpai:         { label: '澎湃新闻', icon: '📱', color: '#E60012' },
  guancha:         { label: '观察者网', icon: '👁️', color: '#2B5797' },
  '163':           { label: '网易新闻', icon: '📰', color: '#DE1A1A' },
  chuangye:        { label: '创业邦',   icon: '🚀', color: '#FF6B35' },
};

const SECTION_ORDER = ['weibo', 'hackernews', 'github', 'producthunt', 'v2ex', 'ithome', '36kr', 'wallstreetcn', 'toutiao', 'douyin', 'news_aggregator', 'bilibili', 'zhihu', 'baidu', 'tieba', 'cailianshe', 'pengpai', 'guancha', '163', 'chuangye'];

const SECTION_CATEGORIES: Record<string, { name: string; icon: string }> = {
  weibo:           { name: '微博热搜',  icon: '🔥' },
  hackernews:      { name: '开发者社区', icon: '💻' },
  github:          { name: '开源项目',  icon: '🐙' },
  producthunt:     { name: '新品发布',  icon: '🚀' },
  v2ex:            { name: 'V2EX 热议', icon: '💬' },
  ithome:          { name: '科技资讯',  icon: '💻' },
  '36kr':          { name: '商业科技',  icon: '📊' },
  wallstreetcn:    { name: '华尔街见闻', icon: '📈' },
  toutiao:         { name: '今日头条',  icon: '📰' },
  douyin:          { name: '抖音',     icon: '🎵' },
  news_aggregator: { name: '快讯聚合',  icon: '📌' },
  bilibili:        { name: 'B站',      icon: '📺' },
  zhihu:           { name: '知乎',     icon: '💡' },
  baidu:           { name: '百度热搜', icon: '🔍' },
  tieba:           { name: '百度贴吧', icon: '📋' },
  cailianshe:      { name: '财联社',   icon: '📡' },
  pengpai:         { name: '澎湃新闻', icon: '📱' },
  guancha:         { name: '观察者网', icon: '👁️' },
  '163':           { name: '网易新闻', icon: '📰' },
  chuangye:        { name: '创业邦',   icon: '🚀' },
};

const grouped: Record<string, any[]> = {};
for (const item of dayData.items) {
  const key = item.platform || 'other';
  if (!grouped[key]) grouped[key] = [];
  grouped[key].push(item);
}

const sortedAll = [...dayData.items].sort((a: any, b: any) => (b.score || 0) - (a.score || 0));
const featured = sortedAll.slice(0, 5);

const trending = [...dayData.items]
  .sort((a: any, b: any) => (b.hot || 0) - (a.hot || 0))
  .slice(0, 10);

const activeSections = SECTION_ORDER.filter(s => (grouped[s]?.length || 0) > 0);

const NAV_TABS = [
  { id: 'featured', label: '精选', icon: '⭐' },
  ...activeSections.map(s => ({
    id: `section-${s}`,
    label: SECTION_CATEGORIES[s]?.name || s,
    icon: SECTION_CATEGORIES[s]?.icon || '📌',
  })),
];

const allDates = getAllDates('zh');
const idx = allDates.indexOf(date);
const prevDay = idx < allDates.length - 1 ? allDates[idx + 1] : null;
const nextDay = idx > 0 ? allDates[idx - 1] : null;

const recentDates = allDates.slice(0, 12);

const dowLabels = ['周一','周二','周三','周四','周五','周六','周日'];
function getDow(d: string) {
  const ndx = new Date(d + 'T00:00:00').getDay();
  return dowLabels[ndx === 0 ? 6 : ndx - 1];
}
---

<BaseLayout title={`📡 ${date} 情报日报 · 豆子实验室`} lang="zh-CN">
<div class="page">

  <!-- Header -->
  <header class="header">
    <div class="header-brand">
      <img src="/icon.svg" alt="" width="36" height="36">
      <div class="header-logo-text">
        <span class="logo-line1">每日<span class="logo-accent">情报</span></span>
        <span class="logo-line2"><span class="logo-accent">豆子</span><span class="logo-dot">·</span>实验室</span>
      </div>
      <span style="font-size:0.8em;color:var(--text-m);font-weight:500;margin-left:6px;">日报 · {date}</span>
    </div>
    <div class="header-meta">
      <span class="count-badge">{totalItems} 条情报</span>
      <a href="https://www.aliyun.com/minisite/goods?userCode=za8gqbw7" target="_blank" rel="noopener" class="badge-link">☁️ 阿里云 1折起</a>
      <a id="tencentPromo" href="https://cloud.tencent.com/act/cps/redirect?redirect=1079&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console" target="_blank" rel="noopener" class="badge-link tencent">💙 腾讯云 79元/年</a>
    </div>
    <div class="header-actions">
      <a href="/" class="lang-btn">← 返回首页</a>
      <button id="themeToggle" class="theme-btn" aria-label="切换主题">🌙</button>
    </div>
  </header>

  <!-- Day Navigation -->
  <div style="display:flex;align-items:center;justify-content:center;gap:16px;margin-bottom:24px;">
    {prevDay ? <a href={`/day/${prevDay}`} style="font-size:0.85em;color:var(--text-m);padding:6px 14px;border:1px solid var(--border);border-radius:8px;font-weight:600;">← {prevDay}</a> : <span style="width:90px"></span>}
    <span style="font-size:0.9em;font-weight:700;color:var(--text-h);font-family:var(--font-mono);">{date} {getDow(date)}</span>
    {nextDay ? <a href={`/day/${nextDay}`} style="font-size:0.85em;color:var(--text-m);padding:6px 14px;border:1px solid var(--border);border-radius:8px;font-weight:600;">{nextDay} →</a> : <span style="width:90px"></span>}
  </div>

  <!-- Header thin banner -->
  {totalItems > 0 && (
    <div class="header-ad" id="headerAd">
      <a id="headerAdLink" href="https://cloud.tencent.com/act/cps/redirect?redirect=6544&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console" target="_blank" rel="noopener">
        <img id="headerAdImg" src="/assets/ads/tencent/banner/return_970_90.png" alt="腾讯云推广" loading="lazy">
      </a>
    </div>
  )}

</div>

<!-- Section Nav -->
<div class="section-nav-wrap">
  <nav class="section-nav" id="sectionNav">
    {NAV_TABS.map(tab => (
      <a href={`#${tab.id}`} data-target={tab.id} class={tab.id === 'featured' ? 'active' : ''}>
        {tab.icon} {tab.label}
      </a>
    ))}
  </nav>
</div>

<div class="page">

  <!-- Today's Focus (only if matches this day) -->
  {focusData && focusData.date === date && focusData.highlights && focusData.highlights.length > 0 && (
    <div class="focus-section">
      <div class="focus-header">
        <span class="focus-title">📋 今日重点</span>
        <span class="focus-date">{focusData.date}</span>
      </div>
      {focusData.summary && <div class="focus-summary">{focusData.summary}</div>}
      {focusData.trends && focusData.trends.length > 0 && (
        <div class="focus-trends">
          {focusData.trends.map((t: string) => <span class="trend-tag">{t}</span>)}
        </div>
      )}
      {focusData.trendAnalysis && (
        <div class="focus-analysis">📊 {focusData.trendAnalysis}</div>
      )}
      <div class="focus-list">
        {focusData.highlights.map((h: any) => (
          <a href={`/focus/${h.rank}/`} class="focus-item">
            <span class="focus-rank">#{h.rank}</span>
            <div class="focus-body">
              <div class="focus-item-title">{h.title}</div>
              <div class="focus-meta">
                <span class="focus-reason">⚡ {h.reason}</span>
                {h.insight && <span class="focus-insight">💡 {h.insight}</span>}
                {h.source && <span class="focus-source">{h.source}</span>}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Content Grid -->
  <div class="content-grid">
    <div class="main-content">

      <!-- Featured Bento -->
      <section id="featured" class="featured-bento">
        {featured.length > 0 && (
          <>
            <div class="featured-hero">
              {featured.slice(0, 3).map((item, idx) => {
                const meta = PLATFORM_META[item.platform] || { label: item.platform_label || item.platform, icon: '📌', color: '#94A3B8' };
                return (
                  <div class="hero-entry">
                    <div class="hero-entry-rank">{idx === 0 ? '★ 精选头条' : `#${idx + 1} 精选`}</div>
                    <div class="hero-entry-title"><a href={item.url} target="_blank" rel="noopener">{item.title}</a></div>
                    <div class="hero-entry-meta">
                      <span class="platform-tag" style={`--tag-color:${meta.color}`}>
                        <span class="tag-icon">{meta.icon}</span>
                        {meta.label}
                      </span>
                      {item.score > 0 && <span class={`signal-badge ${item.score >= 8 ? 'high' : item.score >= 6 ? 'med' : ''}`}>信号 {item.score}</span>}
                    </div>
                  </div>
                );
              })}
            </div>

            {featured.length > 3 && (
              <div class="featured-side">
                {featured.slice(3).map((item, idx) => {
                  const meta = PLATFORM_META[item.platform] || { label: item.platform_label || item.platform, icon: '📌', color: '#94A3B8' };
                  return (
                    <div class="featured-mini">
                      <span class="mini-rank">#{idx + 4} 推荐</span>
                      <a href={item.url} target="_blank" rel="noopener" class="mini-title">{item.title}</a>
                      <span class="platform-tag" style={`--tag-color:${meta.color}`}>
                        <span class="tag-icon">{meta.icon}</span>
                        {meta.label}
                      </span>
                      {item.score > 0 && <span class={`signal-badge ${item.score >= 8 ? 'high' : item.score >= 6 ? 'med' : ''}`}>信号 {item.score}</span>}
                    </div>
                  );
                })}
              </div>
            )}
          </>
        )}
      </section>

      <!-- Platform Grid -->
      <div class="platform-grid">
        {activeSections.map(sectionKey => {
          const items = grouped[sectionKey];
          const sec = SECTION_CATEGORIES[sectionKey] || { name: sectionKey, icon: '📌' };
          const meta = PLATFORM_META[sectionKey] || { label: sectionKey, color: '#94a3b8', icon: '📌' };

          return (
            <section class="platform-section" id={`section-${sectionKey}`}>
              <div class="section-header">
                <div class="section-title">
                  <span>{sec.icon}</span>
                  <span style={`color:${meta.color}`}>{sec.name}</span>
                  <span class="section-count">{items.length}</span>
                </div>
              </div>
              <div class="news-list">
                {items.map((item: any, idx: number) => {
                  const hotValue = item.hot || 0;
                  const sources = item.merged_sources || [item];
                  const primarySource = sources[0];
                  const extraSources = sources.slice(1);
                  return (
                    <div class={`news-item ${item.score >= 7 ? 'score-high' : item.score >= 5 ? 'score-med' : ''}`} style={`--tag-color:${primarySource.color}`}>
                      <span class="news-idx">{idx + 1}</span>
                      <div class="news-body">
                        <a href={item.url} target="_blank" rel="noopener" class="news-title">{item.title}</a>
                        <div class="news-footer">
                          <div class="source-tags">
                            <span class="platform-tag" style={`--tag-color:${primarySource.color}`}>
                              <span class="tag-icon">{primarySource.icon}</span>
                              {primarySource.label}
                            </span>
                            {extraSources.map((s: any) => (
                              <span class="platform-tag platform-tag-sm" style={`--tag-color:${s.color}`} title={s.label}>
                                <span class="tag-icon">{s.icon}</span>
                              </span>
                            ))}
                            {item.merged_sources && <span class="merge-count">+{extraSources.length}</span>}
                          </div>
                          {hotValue > 0 && <span class="news-hot">🔥 {hotValue}</span>}
                          {item.score > 0 && <span class="news-score">信号 <strong>{item.score}</strong></span>}
                        </div>
                        {item.desc && <div class="news-desc">{item.desc}</div>}
                      </div>
                    </div>
                  );
                })}
              </div>
            </section>
          );
        })}
      </div>

      <!-- Native feed-style ad -->
      {totalItems > 0 && (
        <div class="section" style="margin-bottom:0;">
          <div class="section-header">
            <div class="section-title" style="font-size:0.9em;">💡 推荐</div>
          </div>
          <div class="news-list">
            <div class="news-item" style="--tag-color:#3395FF">
              <span class="news-idx" style="color:var(--accent);">💡</span>
              <div class="news-body">
                <a href="https://cloud.tencent.com/act/cps/redirect?redirect=6544&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console" target="_blank" rel="noopener" class="news-title">腾讯云 AI 焕新季 · 2核2G4M 新客仅 99元/年</a>
                <div class="news-footer">
                  <span class="platform-tag" style="--tag-color:#3395FF">☁️ 腾讯云</span>
                  <span class="news-hot" style="color:var(--accent);">推广</span>
                </div>
                <div class="news-desc">轻量应用服务器 4核4G3M 首年 79元，限时特惠中</div>
              </div>
            </div>
          </div>
        </div>
      )}

      <!-- Native Ad: 腾讯云（自动轮换） -->
      {totalItems > 0 && (
        <div id="tencentAd" class="ad-card-img" style="display:block;text-decoration:none;">
          <a id="tencentAdLink" href="https://cloud.tencent.com/act/cps/redirect?redirect=6544&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console" target="_blank" rel="noopener">
            <img id="tencentAdImg" src="/assets/ads/tencent/banner/ai_banner.png" alt="腾讯云推广" loading="lazy" style="width:100%;height:auto;border-radius:12px;display:block;">
          </a>
        </div>
      )}

      <!-- Calendar -->
      {allDates.length > 0 && (
        <section class="section section-full">
          <CalendarWidget dates={allDates} basePath="/day/" locale="zh" currentDate={date} />
        </section>
      )}
    </div>

    <!-- Sidebar -->
    <aside class="sidebar">

      <!-- 公众号关注 -->
      <div class="sidebar-widget">
        <div class="sidebar-widget-title">📢 豆子实验室</div>
        <div style="text-align:center;">
          <div style="font-size:0.82em;font-weight:600;color:var(--text-h);margin-bottom:8px;">每日情报 · 技术干货</div>
          <a href="https://weixin.qq.com" target="_blank" rel="noopener" style="display:block;margin:0 auto 10px;max-width:260px;border-radius:10px;overflow:hidden;border:1px solid var(--border);transition:border-color 0.2s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
            <img src="/assets/brand/wechat/wechat_search_qr.png" alt="微信搜索「豆子实验室」" loading="lazy" style="width:100%;height:auto;display:block;">
          </a>
          <div style="font-size:0.72em;color:var(--text-m);line-height:1.6;">
            📱 微信搜索 <strong style="color:var(--accent);">「豆子实验室」</strong> 或扫码关注
          </div>
        </div>
        {filteredArticles.length > 0 && (
          <div style="margin-top:12px;border-top:1px solid var(--border);padding-top:10px;">
            <div style="font-size:0.75em;font-weight:700;color:var(--text-h);margin-bottom:8px;">📰 最新文章</div>
            <div style="display:flex;flex-direction:column;gap:6px;">
              {filteredArticles.slice(0, 5).map(a => (
                <a href={a.url} target="_blank" rel="noopener" style="font-size:0.72em;line-height:1.4;color:var(--text-p);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;transition:color 0.12s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-p)'">
                  {a.date && <span style="color:var(--text-m);font-size:0.85em;">[{a.date}] </span>}{a.title}
                </a>
              ))}
            </div>
            <div style="margin-top:8px;font-size:0.72em;color:var(--text-m);text-align:center;">在微信搜索「豆子实验室」查看全部文章</div>
          </div>
        )}
      </div>

      <!-- 资源福利 -->
      <div class="sidebar-widget">
        <div class="sidebar-widget-title">🎁 资源福利</div>
        <div style="font-size:0.72em;font-weight:600;color:var(--text-m);padding:6px 0 3px;letter-spacing:0.3px;">🎒 幼小初教辅资料</div>
        <div style="display:flex;flex-direction:column;gap:3px;">
          <a href="https://pan.quark.cn/s/c109909b8f8e" target="_blank" rel="noopener" style="font-size:0.72em;padding:5px 8px;background:var(--bg);border-radius:5px;color:var(--text-p);display:flex;align-items:center;gap:6px;transition:all 0.12s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-p)'"><span>📖</span><span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;">幼小衔接资料合集</span><span style="font-size:0.7em;opacity:0.5;">↗</span></a>
          <a href="https://pan.quark.cn/s/9562e1cc5bcf" target="_blank" rel="noopener" style="font-size:0.72em;padding:5px 8px;background:var(--bg);border-radius:5px;color:var(--text-p);display:flex;align-items:center;gap:6px;transition:all 0.12s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-p)'"><span>📖</span><span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;">小学 1-6 年级全学科试卷</span><span style="font-size:0.7em;opacity:0.5;">↗</span></a>
          <a href="https://pan.quark.cn/s/13c0a70fcb93" target="_blank" rel="noopener" style="font-size:0.72em;padding:5px 8px;background:var(--bg);border-radius:5px;color:var(--text-p);display:flex;align-items:center;gap:6px;transition:all 0.12s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-p)'"><span>📖</span><span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;">小学生手抄报</span><span style="font-size:0.7em;opacity:0.5;">↗</span></a>
