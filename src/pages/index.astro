---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDayData, getAllDates, PLATFORMS } from '../utils/data.ts';

const today = new Date().toISOString().slice(0, 10);
const dayData = getDayData(today, 'zh');

// Mix all items and sort by Score (Primary) and Hot (Secondary)
const allItems = dayData.items.sort((a: any, b: any) => {
  if (b.score !== a.score) return b.score - a.score;
  return b.hot - a.hot;
});

const recentDates = getAllDates('zh').slice(0, 5);
---

<BaseLayout title="📡 INTEL.SYS · AI Semantic Stream">
<div class="app-container">

  <!-- Header -->
  <header class="header">
    <div class="logo">INTEL<span>.SYS</span></div>
    <div style="display: flex; gap: 16px; align-items: center;">
      <a href="/en" style="font-size: 0.85em; font-weight: 600;">EN Version</a>
      <button id="themeToggle" class="theme-toggle" aria-label="Toggle Theme">
        <span class="icon-sun" style="display:none">☀️</span>
        <span class="icon-moon">🌙</span>
      </button>
    </div>
  </header>

  <!-- AI Semantic Grid -->
  <main class="stream-grid">
    {allItems.map((it: any) => {
      const isFeatured = it.score >= 9;
      const meta = PLATFORMS[it.platform] || { label: it.platform_label, icon: '📌' };
      return (
        <article class={`stream-card ${isFeatured ? 'card-featured' : ''}`}>
          <div class="platform-tag">
            <span>{meta.icon}</span>
            <span>{it.platform_label || meta.label}</span>
          </div>
          
          {/* AI 摘要成为主角 */}
          <div class="ai-summary">
            {it.desc || it.title}
          </div>
          
          {/* 原始标题缩小显示，作为辅助 */}
          <a href={it.url} target="_blank" class="news-title">
             Source: {it.title}
          </a>
          
          <div class="card-footer">
            <span class="score-badge">SIGNAL {it.score.toFixed(1)}</span>
            <span>{it.date}</span>
          </div>
        </article>
      );
    })}
  </main>

  <footer style="margin-top: 80px; text-align: center; font-size: 0.8em; color: var(--text-m);">
    📡 Powered by Zhipu GLM-4-Air · Semantic Intelligence Hub · {today}
  </footer>

</div>

<script>
  // Theme Switching Logic
  const themeToggle = document.getElementById('themeToggle');
  const sunIcon = document.querySelector('.icon-sun') as HTMLElement;
  const moonIcon = document.querySelector('.icon-moon') as HTMLElement;
  
  // Check local storage or preference
  let currentTheme = localStorage.getItem('theme') || 'dark';
  document.documentElement.setAttribute('data-theme', currentTheme);
  updateIcons(currentTheme);

  themeToggle?.addEventListener('click', () => {
    currentTheme = currentTheme === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', currentTheme);
    localStorage.setItem('theme', currentTheme);
    updateIcons(currentTheme);
  });

  function updateIcons(theme: string) {
    if (theme === 'light') {
      sunIcon.style.display = 'none';
      moonIcon.style.display = 'block'; // Show moon to switch to dark
      moonIcon.textContent = '🌙';
    } else {
      sunIcon.style.display = 'block'; // Show sun to switch to light
      sunIcon.textContent = '☀️';
      moonIcon.style.display = 'none';
    }
  }
</script>
</BaseLayout>
