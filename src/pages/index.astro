---
// 首页 — 使用共享组件，消除 DRY 违反
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FocusSection from '../components/FocusSection.astro';
import PlatformSection from '../components/PlatformSection.astro';
import Sidebar from '../components/Sidebar.astro';
import SectionNav from '../components/SectionNav.astro';
import PickSection from '../components/PickSection.astro';
import CalendarWidget from '../components/CalendarWidget.astro';
import { getDayData, getAllDates } from '../utils/data.ts';
import { SITE, SECTION_ORDER, getPlatformMeta } from '../lib/constants';
import type { FocusData, IntelItem, GzhArticle, V4DailyData } from '../lib/types';
import articles from '../data/gzh-articles.json';

// ── 数据加载 ──
let focusData: FocusData | null = null;
try {
  const mod = await import('../data/rewrite/today-focus.json');
  focusData = mod.default as FocusData;
} catch {}

// ── V4 精选数据加载 ──
let v4Data: V4DailyData | null = null;
try {
  const v4Index = await import('../data/v4/index.json');
  const latestDate = v4Index.default.latest_date;
  if (latestDate) {
    const mod = await import(`../data/v4/daily-${latestDate}.json`);
    v4Data = mod.default as V4DailyData;
  }
} catch {}

const filteredArticles: GzhArticle[] = articles.filter((a: GzhArticle) => a.title);

const allDates = getAllDates('zh');
const today = allDates.length > 0 ? allDates[0] : new Date().toISOString().slice(0, 10);
const dayData = getDayData(today, 'zh');
const items: IntelItem[] = dayData.items;
const totalItems = items.length;
const recentDates = allDates.slice(0, 10);

// ── 数据分组与排序 ──
const grouped: Record<string, IntelItem[]> = {};
for (const item of items) {
  const key = item.platform || 'other';
  if (!grouped[key]) grouped[key] = [];
  grouped[key].push(item);
}

const sortedAll = [...items].sort((a, b) => (b.score || 0) - (a.score || 0));
const featured = sortedAll.slice(0, 5);

const trending = [...items]
  .sort((a, b) => (b.hot || 0) - (a.hot || 0))
  .slice(0, 10);

const activeSections = SECTION_ORDER.filter(s => (grouped[s]?.length || 0) > 0);
const highScoreCount = items.filter(i => i.score >= 7).length;
---

<BaseLayout title={`${SITE.name} · 每日情报`} lang="zh-CN">
<div class="page">
  <Header mode="home" date={today} totalItems={totalItems} today={today} />

</div>

<SectionNav activeSections={activeSections} locale="zh" />

<div class="page">
  <!-- 今日重点 AI 编辑推荐（唯一 Hero） -->
  <FocusSection focusData={focusData} today={today} />

  <!-- 每日精选（来自 dashboard_v4） -->
  <PickSection data={v4Data} />

  <!-- 今日数据摘要横条 -->
  <div class="stats-bar">
    <div class="stats-bar-item">
      <span class="stats-bar-value">{totalItems}</span>
      <span class="stats-bar-label">今日情报</span>
    </div>
    <div class="stats-bar-divider"></div>
    <div class="stats-bar-item">
      <span class="stats-bar-value">{activeSections.length}</span>
      <span class="stats-bar-label">信息来源</span>
    </div>
    <div class="stats-bar-divider"></div>
    <div class="stats-bar-item highlight">
      <span class="stats-bar-value">{highScoreCount}</span>
      <span class="stats-bar-label">高价值信号</span>
    </div>
  </div>

  <!-- 主内容区 -->
  <div class="content-grid">
    <div class="main-content">
      <!-- 平台分区列表（主要内容） -->
      <PlatformSection grouped={grouped} locale="zh" />

      <!-- 日历 -->
      {allDates.length > 0 && (
        <section class="section section-full">
          <CalendarWidget dates={allDates} basePath="/day/" locale="zh" />
        </section>
      )}

    </div>

    <!-- 侧边栏 -->
    <Sidebar
      totalItems={totalItems}
      activeSectionCount={activeSections.length}
      coverageDays={recentDates.length}
      highScoreCount={highScoreCount}
      grouped={grouped}
      featured={featured}
      trending={trending}
      filteredArticles={filteredArticles}
      locale="zh"
    />
  </div>

  <Footer />
</div>

<button id="backToTop" class="back-to-top" aria-label="回到顶部">↑</button>
</BaseLayout>

<style>
html { scroll-behavior: smooth; }

/* 内容区布局 */
.content-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 28px;
}

@media (min-width: 1024px) {
  .content-grid {
    grid-template-columns: 1fr 300px;
    gap: 36px;
  }
}

.main-content {
  display: flex;
  flex-direction: column;
  gap: 40px;
  min-width: 0;
}

/* ── Stats Summary Bar ── */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  padding: 16px 24px;
  margin-bottom: 8px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 14px;
}

.stats-bar-item {
  text-align: center;
  padding: 0 28px;
}

.stats-bar-item.highlight .stats-bar-value {
  color: var(--accent);
}

.stats-bar-value {
  display: block;
  font-family: var(--font-mono);
  font-size: 1.4em;
  font-weight: 800;
  color: var(--text-h);
  font-variant-numeric: tabular-nums;
}

.stats-bar-label {
  display: block;
  font-size: 0.7em;
  color: var(--text-m);
  margin-top: 2px;
  font-weight: 500;
}

.stats-bar-divider {
  width: 1px;
  height: 32px;
  background: var(--border);
}

@media (max-width: 640px) {
  .stats-bar {
    padding: 14px 12px;
  }
  .stats-bar-item {
    padding: 0 16px;
  }
  .stats-bar-value {
    font-size: 1.1em;
  }
  .main-content {
    gap: 28px;
  }
}

/* 返回顶部 */
.back-to-top {
  position: fixed;
  bottom: 32px;
  right: 32px;
  width: 44px;
  height: 44px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: var(--bg-card);
  color: var(--text-m);
  font-size: 1.2em;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: translateY(10px);
  transition: all 0.2s;
  z-index: 200;
  box-shadow: var(--shadow-md);
}
.back-to-top.visible { opacity: 1; transform: translateY(0); }
.back-to-top:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }

@media (max-width: 768px) {
  .back-to-top { bottom: 20px; right: 20px; width: 40px; height: 40px; }
}
</style>

<script>
  // 分区导航 IntersectionObserver
  const nav = document.getElementById('sectionNav');
  if (nav) {
    const links = nav.querySelectorAll('a[data-target]');
    const sections = Array.from(links).map(link => {
      const id = link.getAttribute('data-target');
      return id ? document.getElementById(id) : null;
    }).filter(Boolean) as HTMLElement[];

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          links.forEach(link => {
            link.classList.toggle('active', link.getAttribute('data-target') === id);
          });
        }
      });
    }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });

    sections.forEach(section => observer.observe(section));
  }

  // 返回顶部
  const backBtn = document.getElementById('backToTop');
  if (backBtn) {
    window.addEventListener('scroll', () => {
      backBtn.classList.toggle('visible', window.scrollY > 400);
    });
    backBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  }

</script>

