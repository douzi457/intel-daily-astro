</style>

<script>
  // Theme toggle
  const themeBtn = document.getElementById('themeToggle');
  if (themeBtn) {
    let theme = localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-theme', theme);
    themeBtn.textContent = theme === 'dark' ? '☀️' : '🌙';
    themeBtn.addEventListener('click', () => {
      theme = theme === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
      themeBtn.textContent = theme === 'dark' ? '☀️' : '🌙';
    });
  }

  // Section nav active state (IntersectionObserver)
  const nav = document.getElementById('sectionNav');
  if (nav) {
    const links = nav.querySelectorAll('a');
    const sections = Array.from(links).map(link => {
      const id = link.getAttribute('data-target');
      return id ? document.getElementById(id) : null;
    }).filter(Boolean);

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          links.forEach(link => {
            link.classList.toggle('active', link.getAttribute('data-target') === id);
          });
        }
      });
    }, {
      rootMargin: '-80px 0px -60% 0px',
      threshold: 0,
    });

    sections.forEach(section => {
      if (section) observer.observe(section);
    });
  }

  // Back to top
  const backBtn = document.getElementById('backToTop');
  if (backBtn) {
    window.addEventListener('scroll', () => {
      backBtn.classList.toggle('visible', window.scrollY > 400);
    });
    backBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  // Tencent Cloud banner rotation (main)
  const adImg = document.getElementById('tencentAdImg');
  const adLink = document.getElementById('tencentAdLink');
  if (adImg && adLink) {
    const promos = [
      { src: '/assets/ads/tencent/banner/ai_banner.png', href: 'https://cloud.tencent.com/act/cps/redirect?redirect=6544&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console', alt: '腾讯云 AI焕新季 · 2核2G4M 新客 99元/年' },
      { src: '/assets/ads/tencent/banner/lighthouse_480_300.png', href: 'https://cloud.tencent.com/act/cps/redirect?redirect=1079&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console', alt: '腾讯云 · 轻量服务器 4核4G3M 仅 79元/年' },
      { src: '/assets/ads/tencent/banner/return_970_250.png', href: 'https://cloud.tencent.com/act/cps/redirect?redirect=2446&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console', alt: '腾讯云 · 推广大使特惠合集' },
    ];
    let idx = 0;
    setInterval(() => {
      idx = (idx + 1) % promos.length;
      const p = promos[idx];
      adImg.src = p.src;
      adImg.alt = p.alt;
      adLink.href = p.href;
    }, 25000);
  }

  // Header thin banner rotation
  const headerImg = document.getElementById('headerAdImg');
  const headerLink = document.getElementById('headerAdLink');
  if (headerImg && headerLink) {
    const ads = [
      { src: '/assets/ads/tencent/banner/return_970_90.png', href: 'https://cloud.tencent.com/act/cps/redirect?redirect=6544&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console', alt: '腾讯云 AI焕新季' },
      { src: '/assets/ads/tencent/banner/lighthouse_1200_90.png', href: 'https://cloud.tencent.com/act/cps/redirect?redirect=1079&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console', alt: '腾讯云 · 轻量服务器 79元/年' },
    ];
    let hi = 0;
    setInterval(() => {
      hi = (hi + 1) % ads.length;
      const p = ads[hi];
      headerImg.src = p.src;
      headerImg.alt = p.alt;
      headerLink.href = p.href;
    }, 20000);
  }

  // Header rotating Tencent promo badge
  const promoEl = document.getElementById('tencentPromo');
  if (promoEl) {
    const promos = [
      { text: '💙 轻量服务器 4核4G3M 79元/年', href: 'https://cloud.tencent.com/act/cps/redirect?redirect=1079&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console' },
      { text: '🤖 AI焕新季 2核2G4M 99元/年', href: 'https://cloud.tencent.com/act/cps/redirect?redirect=6544&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console' },
      { text: '🎁 推广大使特惠合集', href: 'https://cloud.tencent.com/act/cps/redirect?redirect=2446&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console' },
    ];
    let pi = 0;
    setInterval(() => {
      pi = (pi + 1) % promos.length;
      const p = promos[pi];
      promoEl.textContent = p.text;
      promoEl.href = p.href;
    }, 8000);
  }

</script>
