---
import BaseLayout from '../layouts/BaseLayout.astro';
import { TABS, TAB_COLORS, TAB_ICONS, PLATFORMS, getDayData, getAllDates } from '../utils/data.ts';

const today = new Date().toISOString().slice(0, 10);
const dayData = getDayData(today, 'zh');

// 按平台对数据进行分组
const groupedItems: Record<string, any[]> = {};
dayData.items.forEach((it: any) => {
  if (!groupedItems[it.platform]) groupedItems[it.platform] = [];
  groupedItems[it.platform].push(it);
});

// 对每个平台的 item 按分数排序并截取前 6 条
Object.keys(groupedItems).forEach(p => {
  groupedItems[p] = groupedItems[p].sort((a, b) => b.score - a.score).slice(0, 8);
});

const recentDates = getAllDates('zh').slice(0, 7);
---

<BaseLayout title="📡 INTEL.SYS · 全球情报看板">
<div class="dashboard">

  <!-- Header -->
  <header class="header">
    <div class="header-left">
      <div class="logo">INTEL<span>.SYS</span></div>
      <div class="status-bar"><span class="pulse"></span> 系统实时监控中</div>
    </div>
    <div class="header-right">
       <nav class="top-nav">
         <a href="/en" class="lang-switch">EN Version</a>
         <a href="/archive">历史归档</a>
         <a href="/stats">数据统计</a>
       </nav>
    </div>
  </header>

  <!-- Dashboard Grid -->
  <main class="grid-container">
    {Object.entries(groupedItems).map(([p, items]) => {
      const meta = PLATFORMS[p] || { label: p, color: '#94a3b8', icon: '📌' };
      return (
        <section class="platform-card" style={`--p-color: ${meta.color}`}>
          <div class="card-header">
             <div class="p-info">
               <span class="p-icon">{meta.icon}</span>
               <span class="p-name">{meta.label}</span>
             </div>
             <span class="p-update">刚刚更新</span>
          </div>
          <div class="card-body">
            {items.map((it, idx) => (
              <div class="news-item">
                <span class="news-idx">{idx + 1}</span>
                <div class="news-content">
                  <a href={it.url} target="_blank" class="news-title">{it.title}</a>
                  <div class="news-meta">
                    {it.hot_stars > 0 && <span class="news-hot">{'🔥'.repeat(it.hot_stars)}</span>}
                    <span class="news-time">{it.date}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
          <a href={`/day/${today}?platform=${p}`} class="card-footer">查看更多</a>
        </section>
      );
    })}
  </main>

  <!-- Ad Banner -->
  <div class="ad-bottom">
    <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-YOUR_ID" data-ad-slot="YOUR_SLOT" data-ad-format="auto"></ins>
  </div>

</div>
</BaseLayout>
