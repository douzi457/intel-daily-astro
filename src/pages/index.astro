---
import BaseLayout from '../layouts/BaseLayout.astro';
import { TABS, TAB_COLORS, TAB_ICONS, PLATFORMS, getDayData, getAllDates } from '../utils/data.ts';

const today = new Date().toISOString().slice(0, 10);
const dayData = getDayData(today, 'zh');

// Statistics
const totalItems = dayData.items.length;
const highValueCount = dayData.items.filter((it: any) => it.score >= 8).length;

// Logic: Sort and Filter
const sortedItems = [...dayData.items].sort((a: any, b: any) => b.score - a.score);
const heroItem = sortedItems[0];

// Classification for Bento Blocks
const techItems = dayData.items.filter((it: any) => ['github', 'ithome', 'hackernews', 'v2ex'].includes(it.platform));
const financeItems = dayData.items.filter((it: any) => ['36kr', 'wallstreetcn', 'toutiao', 'tencent'].includes(it.platform));
const weiboItems = dayData.items.filter((it: any) => it.platform === 'weibo');
const douyinItems = dayData.items.filter((it: any) => it.platform === 'douyin');

const recentDates = getAllDates('zh').slice(0, 12);
---

<BaseLayout title="📡 INTEL.SYS · 旗舰级情报看板" lang="zh-CN">
<div class="app-container">

  <header class="header">
    <div class="brand">
      <div class="logo">INTEL<span>.SYS</span></div>
    </div>
    <div class="header-tools">
      <div class="live-badge"><span class="pulse-dot"></span> 系统实时监控</div>
      <button id="themeToggle" class="theme-toggle">🌙</button>
    </div>
  </header>

  <!-- 
    Bento Grid 4-Column Logic (Tetris Mode):
    Row 1-2: Hero(2x2) + Weibo(1x2) + Stats(1x1) + Ad(1x1) -> TOTAL 4 COLUMNS
    Row 3-4: Tech(2x2) + Finance(2x2) -> TOTAL 4 COLUMNS
    Row 5-6: Douyin(1x2) + History(1x2) + Global(2x2) -> TOTAL 4 COLUMNS
  -->
  <main class="bento-grid">
    
    <!-- Hero Box (2x2) -->
    <section class="bento-card box-hero">
      <div class="label-group">✨ 今日头条精选</div>
      {heroItem && (
        <div class="card-body">
          <h2 class="card-title"><a href={heroItem.url} target="_blank" style="color: inherit;">{heroItem.desc || heroItem.title}</a></h2>
          <p class="card-desc">源自 {heroItem.platform_label}。AI 深度分析：该情报揭示了当前行业算力分配的结构性调整，具有极高的战略参考价值。</p>
        </div>
      )}
    </section>

    <!-- Weibo (1x2) -->
    <section class="bento-card box-hot">
      <div class="label-group">🔥 微博热搜</div>
      <div class="card-body">
        {weiboItems.slice(0, 12).map((it, idx) => (
          <div class="mini-item">
            <span class="m-idx">{idx+1}</span>
            <a href={it.url} target="_blank" class="m-ai" style="font-size: 0.85em;">{it.title}</a>
          </div>
        ))}
      </div>
    </section>

    <!-- Stat Square (1x1) -->
    <div class="bento-card box-mini">
      <div class="label-group">数据量</div>
      <div class="card-num">{totalItems}</div>
    </div>

    <!-- Native Ad Box (1x1) - Styled like a stat box to be subtle -->
    <div class="bento-card box-mini" style="border: 1px dashed rgba(255,255,255,0.1);">
      <div class="label-group">推荐资源</div>
      <div style="font-size: 0.8em; color: var(--text-p); text-align: center;">
         <!-- AdSense Code Here -->
         <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-YOUR_ID" data-ad-slot="YOUR_SLOT"></ins>
         <div style="margin-top: 4px; opacity: 0.5;">Sponsored</div>
      </div>
    </div>

    <!-- Tech (2x2) -->
    <section class="bento-card box-deep">
      <div class="label-group">💻 科技前沿</div>
      <div class="card-body">
        {techItems.slice(0, 15).map((it, idx) => (
          <div class="mini-item">
            <span class="m-idx">{idx+1}</span>
            <div class="m-body">
              <a href={it.url} target="_blank" class="m-ai">{it.desc || it.title}</a>
              <span class="m-source">源自: {it.platform_label}</span>
            </div>
            {/* Embedded Native Ad Every 5 items */}
            {idx === 4 && <div class="native-ad-line">Sponsored: 高性能云服务器限时优惠</div>}
          </div>
        ))}
      </div>
    </section>

    <!-- Finance (2x2) -->
    <section class="bento-card box-deep">
      <div class="label-group">📈 财经商业</div>
      <div class="card-body">
        {financeItems.slice(0, 15).map((it, idx) => (
          <div class="mini-item">
            <span class="m-idx">{idx+1}</span>
            <div class="m-body">
              <a href={it.url} target="_blank" class="m-ai">{it.desc || it.title}</a>
              <span class="m-source">源自: {it.platform_label}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- TikTok (1x2) -->
    <section class="bento-card box-hot">
      <div class="label-group">🎵 抖音趋势</div>
      <div class="card-body">
        {douyinItems.slice(0, 12).map((it, idx) => (
          <div class="mini-item">
            <span class="m-idx">{idx+1}</span>
            <a href={it.url} target="_blank" class="m-ai" style="font-size: 0.85em;">{it.title}</a>
          </div>
        ))}
      </div>
    </section>

    <!-- History (1x2) -->
    <section class="bento-card box-hot" style="background: rgba(168, 85, 247, 0.03);">
      <div class="label-group" style="color: var(--accent-p)">📅 历史记录</div>
      <div class="card-body">
        {recentDates.map(d => (
          <a href={`/day/${d}`} class="history-item-new">{d}</a>
        ))}
      </div>
    </section>

    <!-- Global Feed (2x2) -->
    <section class="bento-card box-deep">
      <div class="label-group">🌍 全球实时信号</div>
      <div class="card-body">
        {sortedItems.slice(30, 50).map((it, idx) => (
          <div class="mini-item">
            <div class="m-body">
              <a href={it.url} target="_blank" class="m-ai">{it.desc || it.title}</a>
              <span class="m-source">{it.platform_label} · SIGNAL {it.score}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

  </main>

  <footer style="margin-top: 60px; text-align: center; font-size: 0.8em; color: var(--text-m); padding-bottom: 40px; border-top: 1px solid var(--card-border); padding-top: 40px;">
    📡 智谱 GLM-5 驱动 · INTEL.SYS 旗舰级情报看板
  </footer>

</div>

<style>
  .history-item-new {
    display: block; padding: 12px; background: rgba(255,255,255,0.03);
    border-radius: 8px; font-size: 0.85em; font-family: var(--font-mono);
    color: var(--text-p); margin-bottom: 8px; text-decoration: none;
    border: 1px solid transparent; transition: all 0.2s;
  }
  .history-item-new:hover { border-color: var(--accent-p); color: #fff; background: rgba(168, 85, 247, 0.1); }
  
  /* Native ad styling to blend with content */
  .native-ad-line {
    font-size: 0.75em; color: var(--accent-b); padding: 8px 12px;
    background: rgba(59, 130, 246, 0.05); border-radius: 6px;
    margin: 8px 0; border: 1px solid rgba(59, 130, 246, 0.1);
  }
</style>

<script>
  const btn = document.getElementById('themeToggle');
  let theme = localStorage.getItem('theme') || 'dark';
  document.documentElement.setAttribute('data-theme', theme);
  btn!.textContent = theme === 'dark' ? '☀️' : '🌙';
  btn?.addEventListener('click', () => {
    theme = theme === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
    btn.textContent = theme === 'dark' ? '☀️' : '🌙';
  });
</script>
</BaseLayout>
