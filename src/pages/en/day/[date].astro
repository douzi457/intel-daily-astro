---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { TABS_EN, TAB_COLORS, PLATFORMS_EN, getDayData, getAllDates } from '../../../utils/data.ts';

export async function getStaticPaths() {
  const dates = getAllDates('en');
  return dates.map(d => ({ params: { date: d } }));
}

const { date } = Astro.params as { date: string };
const dayData = getDayData(date, 'en');

const tabCounts: Record<string, number> = {};
TABS_EN.forEach(t => tabCounts[t] = 0);
dayData.items.forEach((it: any) => {
  tabCounts[it.tab || 'Finance'] = (tabCounts[it.tab || 'Finance'] || 0) + 1;
});

const dates = getAllDates('en');
const idx = dates.indexOf(date);
const prevDay = idx < dates.length - 1 ? dates[idx + 1] : null;
const nextDay = idx > 0 ? dates[idx - 1] : null;
---

<BaseLayout title={`📡 ${date} Intelligence Report · INTEL.SYS`} lang="en">
<div class="page">

  <header class="header">
    <div class="header-brand">
      <div class="header-logo">INTEL<span>.SYS</span></div>
      <span style="font-size:0.8em;color:var(--text-m);font-weight:500;margin-left:6px;">{date} Report</span>
    </div>
    <div class="header-meta">
      <span class="count-badge">{dayData.items.length} items</span>
    </div>
    <div class="header-actions">
      <a href="/en/" class="lang-btn">Home</a>
      <a href="/en/archive" class="lang-btn">Archive</a>
      <a href="/" class="lang-btn">中文</a>
      <button id="themeToggle" class="theme-btn" aria-label="Toggle theme">🌙</button>
    </div>
  </header>

  <!-- Day Navigation -->
  <div style="display:flex;align-items:center;justify-content:center;gap:20px;margin-bottom:32px;">
    {prevDay ? <a href={`/en/day/${prevDay}`} style="font-size:1.2em;color:var(--text-m);padding:8px 12px;border:1px solid var(--border);border-radius:8px;">←</a> : <span style="width:38px"></span>}
    <span style="font-size:1.1em;font-weight:700;color:var(--text-h);font-family:var(--font-mono);">{date}</span>
    {nextDay ? <a href={`/en/day/${nextDay}`} style="font-size:1.2em;color:var(--text-m);padding:8px 12px;border:1px solid var(--border);border-radius:8px;">→</a> : <span style="width:38px"></span>}
  </div>

  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:12px;margin-bottom:32px;">
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:16px;text-align:center;">
      <div style="font-size:1.5em;font-weight:800;color:var(--text-h);font-family:var(--font-mono);">{dayData.items.length}</div>
      <div style="font-size:0.75em;color:var(--text-m);margin-top:4px;">Total</div>
    </div>
    {TABS_EN.map(tab => (
      <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:16px;text-align:center;">
        <div style="font-size:1.5em;font-weight:800;color:var(--text-h);font-family:var(--font-mono);">{tabCounts[tab] || 0}</div>
        <div style="font-size:0.75em;color:var(--text-m);margin-top:4px;">{tab}</div>
      </div>
    ))}
  </div>

  <!-- Search & Filter -->
  <div style="display:flex;gap:12px;margin-bottom:24px;flex-wrap:wrap;">
    <input id="searchInput" placeholder="🔍 Search titles..." style="flex:1;min-width:200px;padding:10px 16px;border-radius:10px;border:1px solid var(--border);background:var(--bg-card);color:var(--text-h);font-size:0.85em;font-family:var(--font-sans);" autocomplete="off"/>
    <span id="resultCount" style="font-size:0.8em;color:var(--text-m);padding:10px 0;"></span>
  </div>

  <!-- Tab Filter -->
  <div style="display:flex;gap:8px;margin-bottom:28px;flex-wrap:wrap;">
    <button class="tab-btn active" data-tab="All" style="padding:6px 14px;border-radius:8px;border:1px solid var(--border);background:var(--bg-card);color:var(--text-p);font-size:0.8em;font-weight:600;cursor:pointer;">
      📡 All <span style="font-family:var(--font-mono);font-size:0.85em;margin-left:4px;opacity:0.6;">{dayData.items.length}</span>
    </button>
    {TABS_EN.map(tab => (
      <button class="tab-btn" data-tab={tab} style="padding:6px 14px;border-radius:8px;border:1px solid var(--border);background:var(--bg-card);color:var(--text-p);font-size:0.8em;font-weight:600;cursor:pointer;">
        📌 {tab} <span style="font-family:var(--font-mono);font-size:0.85em;margin-left:4px;opacity:0.6;">{tabCounts[tab] || 0}</span>
      </button>
    ))}
  </div>

  <!-- Items -->
  <div id="itemList" style="display:flex;flex-direction:column;gap:6px;">
    {dayData.items.map((it: any, idx: number) => (
      <div class="news-item" data-tab={it.tab} data-search={it.title + ' ' + (it.desc || '')}>
        <span class="news-idx">{idx + 1}</span>
        <div class="news-body">
          <a href={it.url} target="_blank" rel="noopener" class="news-title">{it.title}</a>
          <div class="news-footer">
            <span class="platform-tag" style={`color:${it.platform_color};border-color:${it.platform_color}20;background:${it.platform_color}10`}>
              <span class="tag-icon">{it.platform_icon || '📌'}</span>
              {PLATFORMS_EN[it.platform] || it.platform}
            </span>
            {it.desc && <span style="font-size:0.75em;color:var(--text-m);">{it.desc}</span>}
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Footer -->
  <div class="footer">📡 INTEL.SYS · {date}</div>

</div>

<style>
  .tab-btn.active {
    border-color: var(--accent) !important;
    color: var(--accent) !important;
    background: var(--accent-glow) !important;
  }
  #searchInput:focus { outline: none; border-color: var(--accent); }
</style>

<script>
  const themeBtn = document.getElementById('themeToggle');
  if (themeBtn) {
    let theme = localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-theme', theme);
    themeBtn.textContent = theme === 'dark' ? '☀️' : '🌙';
    themeBtn.addEventListener('click', () => {
      theme = theme === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
      themeBtn.textContent = theme === 'dark' ? '☀️' : '🌙';
    });
  }

  // Tab filter
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const tab = btn.dataset.tab!;
      document.querySelectorAll('.news-item').forEach(el => {
        const cardTab = (el as HTMLElement).dataset.tab;
        el.style.display = (tab === 'All' || cardTab === tab) ? '' : 'none';
      });
      updateCount();
    });
  });

  // Search
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  if (searchInput) {
    searchInput.addEventListener('input', () => {
      const q = searchInput.value.toLowerCase().trim();
      document.querySelectorAll('.news-item').forEach(el => {
        const searchText = ((el as HTMLElement).dataset.search || '').toLowerCase();
        el.style.display = q === '' || searchText.includes(q) ? '' : 'none';
      });
      updateCount();
    });
  }

  function updateCount() {
    const hint = document.getElementById('resultCount');
    if (!hint) return;
    hint.textContent = `${document.querySelectorAll('.news-item[style*="display: none"]').length === 0 ? document.querySelectorAll('.news-item').length : document.querySelectorAll('.news-item:not([style*="display: none"])').length} items`;
  }
  updateCount();
</script>
</BaseLayout>
