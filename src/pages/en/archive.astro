---
// EN Archive — using shared components
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getAllDates } from '../../utils/data.ts';
import CalendarWidget from '../../components/CalendarWidget.astro';

const dates = getAllDates('en');
---

<BaseLayout title="📁 History Archive · Douzi Labs" lang="en">
<div class="page">
  <Header mode="archive" lang="en" />

  <div style="margin-bottom:40px;">
    <h1 style="font-size:1.4em;font-weight:800;color:var(--text-h);display:flex;align-items:center;gap:8px;">📁 History Archive</h1>
    <p style="font-size:0.82em;color:var(--text-m);margin-top:6px;">{dates.length} days of data</p>
  </div>

  <CalendarWidget dates={dates} basePath="/en/day/" locale="en" />

  <Footer />
</div>
</BaseLayout>
