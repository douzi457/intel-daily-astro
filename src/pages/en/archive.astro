---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllDates } from '../../utils/data.ts';
import CalendarWidget from '../../components/CalendarWidget.astro';

const dates = getAllDates('en');
---

<BaseLayout title="📁 History Archive · INTEL.SYS" lang="en">
<div class="page">

  <header class="header">
    <div class="header-brand">
      <div class="header-logo">INTEL<span>.SYS</span></div>
    </div>
    <div class="header-meta">
      <span class="count-badge">{dates.length} days</span>
    </div>
    <div class="header-actions">
      <a href="/en/" class="lang-btn">← Home</a>
      <a href="/en/stats" class="lang-btn">📊 Stats</a>
      <a href="/" class="lang-btn">中文</a>
      <button id="themeToggle" class="theme-btn" aria-label="Toggle theme">🌙</button>
    </div>
  </header>

  <div style="margin-bottom:40px;">
    <h1 style="font-size:1.4em;font-weight:800;color:var(--text-h);display:flex;align-items:center;gap:8px;">📁 History Archive</h1>
  </div>

  <CalendarWidget dates={dates} basePath="/en/day/" locale="en" />

  <!-- Footer -->
  <div class="footer" style="margin-top:40px;">
    📡 INTEL.SYS · Archive
    <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border);display:flex;flex-wrap:wrap;justify-content:center;gap:8px 16px;font-size:0.85em;">
      <span style="font-weight:700;color:var(--text-h);">🌐 Zhineng Ecosystem</span>
      <a href="https://news.zhinengtech.dpdns.org" target="_blank" rel="noopener" style="color:var(--text-p);text-decoration:none;transition:color 0.12s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-p)'">Zhineng News</a>
      <a href="https://zhinengtools.pages.dev" target="_blank" rel="noopener" style="color:var(--text-p);text-decoration:none;transition:color 0.12s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-p)'">Zhineng Tools</a>
      <a href="https://github.com/weixin008" target="_blank" rel="noopener" style="color:var(--text-p);text-decoration:none;transition:color 0.12s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-p)'">GitHub</a>
      <span style="color:var(--text-m);">💬 WeChat: 豆子实验室</span>
    </div>
  </div>

</div>

<script>
  const btn = document.getElementById('themeToggle');
  if (btn) {
    let theme = localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-theme', theme);
    btn.textContent = theme === 'dark' ? '☀️' : '🌙';
    btn.addEventListener('click', () => {
      theme = theme === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
      btn.textContent = theme === 'dark' ? '☀️' : '🌙';
    });
  }
</script>
</BaseLayout>
