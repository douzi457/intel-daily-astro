---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { TABS_EN, TAB_COLORS, PLATFORMS_EN, PLATFORMS, getDayData, getAllDates } from '../../utils/data.ts';

const today = new Date().toISOString().slice(0, 10);
const dayData = getDayData(today, 'en');

// Group items by platform for the "Intelligence Wall" layout
const groupedItems: Record<string, any[]> = {};
dayData.items.forEach((it: any) => {
  if (!groupedItems[it.platform]) groupedItems[it.platform] = [];
  groupedItems[it.platform].push(it);
});

// Sort each platform by score and take top 8
Object.keys(groupedItems).forEach(p => {
  groupedItems[p] = groupedItems[p].sort((a: any, b: any) => b.score - a.score).slice(0, 8);
});

const recentDates = getAllDates('en').slice(0, 7);
---

<BaseLayout title="📡 INTEL.SYS · Global Intelligence Hub" lang="en">
<div class="dashboard">

  <!-- Header -->
  <header class="header">
    <div class="header-left">
      <div class="logo">INTEL<span>.SYS</span></div>
      <div class="status-bar"><span class="pulse"></span> System Monitoring...</div>
    </div>
    <div class="header-right">
       <nav class="top-nav">
         <a href="/" class="lang-switch">中文版</a>
         <a href="/en/archive">Archive</a>
         <a href="/en/stats">Statistics</a>
       </nav>
    </div>
  </header>

  <!-- Dashboard Grid -->
  <main class="grid-container">
    {Object.entries(groupedItems).map(([p, items]) => {
      const meta = PLATFORMS[p] || { label: p, color: '#94a3b8', icon: '📌' };
      const label = PLATFORMS_EN[p] || meta.label;
      return (
        <section class="platform-card" style={`--p-color: ${meta.color}`}>
          <div class="card-header">
             <div class="p-info">
               <span class="p-icon">{meta.icon}</span>
               <span class="p-name">{label}</span>
             </div>
             <span class="p-update">Just updated</span>
          </div>
          <div class="card-body">
            {items.map((it, idx) => (
              <div class="news-item">
                <span class="news-idx">{idx + 1}</span>
                <div class="news-content">
                  <a href={it.url} target="_blank" class="news-title">{it.title}</a>
                  <div class="news-meta">
                    {it.hot_stars > 0 && <span class="news-hot">{'🔥'.repeat(it.hot_stars)}</span>}
                    <span class="news-time">{it.date}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
          <a href={`/en/day/${today}?platform=${p}`} class="card-footer">View More</a>
        </section>
      );
    })}
  </main>

  <!-- Ad Banner -->
  <div class="ad-bottom">
    <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-YOUR_ID" data-ad-slot="YOUR_SLOT" data-ad-format="auto"></ins>
  </div>

</div>
</BaseLayout>
