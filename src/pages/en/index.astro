---
// EN Homepage — using shared components
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FeaturedSection from '../../components/FeaturedSection.astro';
import PlatformSection from '../../components/PlatformSection.astro';
import Sidebar from '../../components/Sidebar.astro';
import SectionNav from '../../components/SectionNav.astro';
import CalendarWidget from '../../components/CalendarWidget.astro';
import { getDayData, getAllDates } from '../../utils/data.ts';
import { SITE, SECTION_ORDER } from '../../lib/constants';
import type { IntelItem, GzhArticle } from '../../lib/types';
import articles from '../../data/gzh-articles.json';

// Data loading
const filteredArticles: GzhArticle[] = articles.filter((a: GzhArticle) => a.title);

const allDates = getAllDates('en');
const today = allDates.length > 0 ? allDates[0] : new Date().toISOString().slice(0, 10);
const dayData = getDayData(today, 'en');
const items: IntelItem[] = dayData.items;
const totalItems = items.length;
const recentDates = allDates.slice(0, 10);

// Grouping & sorting
const grouped: Record<string, IntelItem[]> = {};
for (const item of items) {
  const key = item.platform || 'other';
  if (!grouped[key]) grouped[key] = [];
  grouped[key].push(item);
}

const sortedAll = [...items].sort((a, b) => (b.score || 0) - (a.score || 0));
const featured = sortedAll.slice(0, 5);
const trending = [...items].sort((a, b) => (b.hot || 0) - (a.hot || 0)).slice(0, 10);
const activeSections = SECTION_ORDER.filter(s => (grouped[s]?.length || 0) > 0);
const highScoreCount = items.filter(i => i.score >= 7).length;

const pageDesc = `Today's tech intelligence briefing from ${SITE.name}. AI-scored news from ${activeSections.length} sources.`;
---

<BaseLayout title="Douzi Labs · Daily Intel" lang="en" description={pageDesc}>
<div class="page">
  <Header mode="en-home" date={today} totalItems={totalItems} lang="en" />

  {totalItems > 0 && (
    <div class="header-ad" id="headerAd">
      <a id="headerAdLink" href="https://cloud.tencent.com/act/cps/redirect?redirect=6544&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console" target="_blank" rel="noopener">
        <img id="headerAdImg" src="/assets/ads/tencent/banner/return_970_90.png" alt="Tencent Cloud" loading="lazy">
      </a>
    </div>
  )}
</div>

<SectionNav activeSections={activeSections} locale="en" />

<div class="page">
  <div class="content-grid">
    <div class="main-content">
      <PlatformSection grouped={grouped} locale="en" />
      <FeaturedSection featured={featured} locale="en" />

      {totalItems > 0 && (
        <div class="section" style="margin-bottom:0;">
          <div class="section-header">
            <div class="section-title" style="font-size:0.9em;">💡 Sponsored</div>
          </div>
          <div class="news-list">
            <div class="news-item" style="--tag-color:#3395FF">
              <span class="news-idx" style="color:var(--accent);">💡</span>
              <div class="news-body">
                <a href="https://cloud.tencent.com/act/cps/redirect?redirect=6544&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console" target="_blank" rel="noopener" class="news-title">Tencent Cloud AI Season · 2C2G4M New Users Only $13.6/yr</a>
                <div class="news-footer">
                  <span class="platform-tag" style="--tag-color:#3395FF">☁️ Tencent Cloud</span>
                  <span class="news-hot" style="color:var(--accent);">Ad</span>
                </div>
                <div class="news-desc">Lightweight Server 4C4G3M from $10.9/yr, limited-time offer</div>
              </div>
            </div>
          </div>
        </div>
      )}

      {allDates.length > 0 && (
        <section class="section section-full">
          <CalendarWidget dates={allDates} basePath="/en/day/" locale="en" />
        </section>
      )}
    </div>

    <Sidebar
      totalItems={totalItems}
      activeSectionCount={activeSections.length}
      coverageDays={recentDates.length}
      highScoreCount={highScoreCount}
      grouped={grouped}
      featured={featured}
      trending={trending}
      filteredArticles={filteredArticles}
      locale="en"
    />
  </div>

  <Footer />
</div>

<button id="backToTop" class="back-to-top" aria-label="Back to top">↑</button>
</BaseLayout>

<style>
html { scroll-behavior: smooth; }

.content-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 28px;
}
@media (min-width: 1024px) {
  .content-grid { grid-template-columns: 1fr 300px; }
}
.main-content {
  display: flex;
  flex-direction: column;
  gap: 28px;
  min-width: 0;
}

.header-ad {
  margin-top: 12px;
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid var(--border);
  transition: border-color 0.2s;
  height: 90px;
}
.header-ad:hover { border-color: var(--accent); }
.header-ad a { display: block; text-decoration: none; height: 100%; }
.header-ad img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.3s; }
.header-ad:hover img { transform: scale(1.01); }

.back-to-top {
  position: fixed;
  bottom: 32px;
  right: 32px;
  width: 44px;
  height: 44px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: var(--bg-card);
  color: var(--text-m);
  font-size: 1.2em;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: translateY(10px);
  transition: all 0.2s;
  z-index: 200;
  box-shadow: var(--shadow-md);
}
.back-to-top.visible { opacity: 1; transform: translateY(0); }
.back-to-top:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }
@media (max-width: 768px) {
  .back-to-top { bottom: 20px; right: 20px; width: 40px; height: 40px; }
}
</style>

<script>
  const nav = document.getElementById('sectionNav');
  if (nav) {
    const links = nav.querySelectorAll('a[data-target]');
    const sections = Array.from(links).map(link => {
      const id = link.getAttribute('data-target');
      return id ? document.getElementById(id) : null;
    }).filter(Boolean) as HTMLElement[];
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          links.forEach(link => link.classList.toggle('active', link.getAttribute('data-target') === id));
        }
      });
    }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });
    sections.forEach(section => observer.observe(section));
  }

  const backBtn = document.getElementById('backToTop');
  if (backBtn) {
    window.addEventListener('scroll', () => backBtn.classList.toggle('visible', window.scrollY > 400));
    backBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  }

  // Header banner rotation
  const headerImg = document.getElementById('headerAdImg') as HTMLImageElement | null;
  const headerLink = document.getElementById('headerAdLink') as HTMLAnchorElement | null;
  if (headerImg && headerLink) {
    const ads = [
      { src: '/assets/ads/tencent/banner/return_970_90.png', href: 'https://cloud.tencent.com/act/cps/redirect?redirect=6544&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console', alt: 'Tencent Cloud AI Season' },
      { src: '/assets/ads/tencent/banner/lighthouse_1200_90.png', href: 'https://cloud.tencent.com/act/cps/redirect?redirect=1079&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console', alt: 'Tencent Cloud · $10.9/yr' },
    ];
    let hi = 0;
    setInterval(() => { hi = (hi + 1) % ads.length; const p = ads[hi]; headerImg.src = p.src; headerImg.alt = p.alt; headerLink.href = p.href; }, 20000);
  }

  const promoEl = document.getElementById('tencentPromo') as HTMLAnchorElement | null;
  if (promoEl) {
    const promos = [
      { text: '💙 Lightweight Server 4C4G3M $10.9/yr', href: 'https://cloud.tencent.com/act/cps/redirect?redirect=1079&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console' },
      { text: '🤖 AI Season 2C2G4M $13.6/yr', href: 'https://cloud.tencent.com/act/cps/redirect?redirect=6544&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console' },
      { text: '🎁 Ambassador Deals', href: 'https://cloud.tencent.com/act/cps/redirect?redirect=2446&cps_key=c7ef87056c14c6dd880836c4671d0001&from=console' },
    ];
    let pi = 0;
    setInterval(() => { pi = (pi + 1) % promos.length; const p = promos[pi]; promoEl.textContent = p.text; promoEl.href = p.href; }, 8000);
  }
</script>
