---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDayData, getAllDates } from '../../utils/data.ts';

const today = new Date().toISOString().slice(0, 10);
const dayData = getDayData(today, 'en');
const totalItems = dayData.items.length;
const recentDates = getAllDates('en').slice(0, 10);

const PLATFORM_META: Record<string, { label: string; icon: string; color: string }> = {
  weibo:           { label: 'Weibo',       icon: '🔥', color: '#FF9500' },
  hackernews:      { label: 'HackerNews',  icon: '⚡', color: '#FF6600' },
  github:          { label: 'GitHub',      icon: '🐙', color: '#6CCB5F' },
  producthunt:     { label: 'ProductHunt', icon: '🚀', color: '#DA5430' },
  v2ex:            { label: 'V2EX',        icon: '💬', color: '#4CAF50' },
  ithome:          { label: 'IT Home',     icon: '💻', color: '#0090D8' },
  '36kr':          { label: '36Kr',        icon: '📊', color: '#4A90E2' },
  wallstreetcn:    { label: 'WallStreetCN', icon: '📈', color: '#3395FF' },
  toutiao:         { label: 'TouTiao',     icon: '📰', color: '#E63946' },
  douyin:          { label: 'Douyin',      icon: '🎵', color: '#00F2EA' },
  news_aggregator: { label: 'News Feed',   icon: '📌', color: '#94A3B8' },
};

const grouped: Record<string, any[]> = {};
for (const item of dayData.items) {
  const key = item.platform || 'other';
  if (!grouped[key]) grouped[key] = [];
  grouped[key].push(item);
}

const sortedAll = [...dayData.items].sort((a: any, b: any) => (b.score || 0) - (a.score || 0));
const featured = sortedAll.slice(0, 5);

const trending = [...dayData.items]
  .sort((a: any, b: any) => (b.hot || 0) - (a.hot || 0))
  .slice(0, 8);

const SECTION_ORDER = ['weibo', 'hackernews', 'github', 'producthunt', 'v2ex', 'ithome', '36kr', 'wallstreetcn', 'toutiao', 'douyin', 'news_aggregator'];
const SECTION_CATEGORIES: Record<string, { name: string; icon: string }> = {
  weibo:           { name: 'Weibo Hot Search',  icon: '🔥' },
  hackernews:      { name: 'Dev Community',     icon: '💻' },
  github:          { name: 'Open Source',       icon: '🐙' },
  producthunt:     { name: 'New Products',      icon: '🚀' },
  v2ex:            { name: 'V2EX Hot',          icon: '💬' },
  ithome:          { name: 'Tech News',         icon: '💻' },
  '36kr':          { name: 'Business Flash',    icon: '📊' },
  wallstreetcn:    { name: 'Finance Insights',  icon: '📈' },
  toutiao:         { name: 'Hot Topics',        icon: '📰' },
  douyin:          { name: 'Douyin Trending',   icon: '🎵' },
  news_aggregator: { name: 'News Digest',       icon: '📌' },
};

const FULL_WIDTH_SECTIONS = new Set(['news_aggregator']);

const activePlatforms = SECTION_ORDER.filter(p => grouped[p]?.length > 0);
const maxPlatformCount = Math.max(...activePlatforms.map(p => grouped[p].length), 1);
const NAV_TABS = [
  { id: 'featured', label: 'Featured', icon: '⭐' },
  ...activePlatforms.map(p => ({
    id: `platform-${p}`,
    label: SECTION_CATEGORIES[p]?.name || p,
    icon: SECTION_CATEGORIES[p]?.icon || '📌',
  })),
];


const dowLabels = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
function getDow(d: string) {
  const idx = new Date(d + 'T00:00:00').getDay();
  return dowLabels[idx === 0 ? 6 : idx - 1];
}
---

<BaseLayout title="DOUZI LABS · Daily Intel" lang="en">
<div class="page">

  <header class="header">
    <div class="header-brand">
      <div class="header-logo">DOUZI<span>.LABS</span></div>
    </div>
    <div class="header-meta">
      <span class="date-badge">{today}</span>
      <span class="count-badge">{totalItems} briefs</span>
    </div>
    <div class="header-actions">
      <a href="/stats" class="lang-btn">📊 Stats</a>
      <a href="/archive" class="lang-btn">📁 Archive</a>
      <a href="/" class="lang-btn">中文</a>
      <button id="themeToggle" class="theme-btn" aria-label="Toggle theme">🌙</button>
    </div>
  </header>

</div>

<!-- Section Nav (full width) -->
<div class="section-nav-wrap">
  <nav class="section-nav" id="sectionNav">
    {NAV_TABS.map(tab => (
      <a href={`#${tab.id}`} data-target={tab.id} class={tab.id === 'featured' ? 'active' : ''}>
        {tab.icon} {tab.label}
      </a>
    ))}
  </nav>
</div>

<div class="page">

  <!-- Content Grid -->
  <div class="content-grid">
    <div class="main-content">

      <!-- Featured Bento -->
      <section id="featured" class="featured-bento">
        {featured.length > 0 && (
          <>
            <div class="featured-hero">
              {featured.slice(0, 3).map((item, idx) => {
                const meta = PLATFORM_META[item.platform] || { label: item.platform_label || item.platform, icon: '📌', color: '#94A3B8' };
                return (
                  <div class="hero-entry">
                    <div class="hero-entry-rank">{idx === 0 ? '★ Top Pick' : `#${idx + 1} Pick`}</div>
                    <div class="hero-entry-title"><a href={item.url} target="_blank" rel="noopener">{item.title}</a></div>
                    <div class="hero-entry-meta">
                      <span class="platform-tag" style={`color:${meta.color};border-color:${meta.color}20;background:${meta.color}10`}>
                        <span class="tag-icon">{meta.icon}</span>
                        {meta.label}
                      </span>
                      {item.score > 0 && <span class={`signal-badge ${item.score >= 8 ? 'high' : item.score >= 6 ? 'med' : ''}`}>SIGNAL {item.score}</span>}
                    </div>
                  </div>
                );
              })}
            </div>

            {featured.length > 3 && (
              <div class="featured-side">
                {featured.slice(3).map((item, idx) => {
                  const meta = PLATFORM_META[item.platform] || { label: item.platform_label || item.platform, icon: '📌', color: '#94A3B8' };
                  return (
                    <div class="featured-mini">
                      <span class="mini-rank">#{idx + 4} Pick</span>
                      <a href={item.url} target="_blank" rel="noopener" class="mini-title">{item.title}</a>
                      <span class="platform-tag" style={`color:${meta.color};border-color:${meta.color}20;background:${meta.color}10`}>
                        <span class="tag-icon">{meta.icon}</span>
                        {meta.label}
                      </span>
                      {item.score > 0 && <span class={`signal-badge ${item.score >= 8 ? 'high' : item.score >= 6 ? 'med' : ''}`}>SIGNAL {item.score}</span>}
                    </div>
                  );
                })}
              </div>
            )}
          </>
        )}
      </section>

      <!-- Native Ad: DigitalOcean -->
      {totalItems > 0 && (
        <a href="https://www.digitalocean.com/affiliates" target="_blank" rel="noopener" class="ad-card" style="display:block;text-decoration:none;">
          <div class="ad-label">—— Sponsored ——</div>
          <div class="ad-content">
            <strong>☁️ DigitalOcean</strong> · New users get <strong>$200 credit</strong>
            <br /><span style="font-size:0.85em;color:var(--text-m);">Reliable cloud infrastructure for dev workloads</span>
          </div>
        </a>
      )}

      <!-- Platform Grid -->
      <div class="platform-grid">
        {activePlatforms.map(platform => {
          const items = grouped[platform];
          const cat = SECTION_CATEGORIES[platform] || { name: platform, icon: '📌' };
          const meta = PLATFORM_META[platform] || { label: platform, icon: '📌', color: '#94A3B8' };
          const isFullWidth = FULL_WIDTH_SECTIONS.has(platform);

          return (
            <section class={`platform-section ${isFullWidth ? 'section-full' : ''}`} id={`platform-${platform}`}>
              <div class="section-header">
                <div class="section-title">
                  <span>{cat.icon}</span>
                  <span>{cat.name}</span>
                  <span class="section-count">{items.length}</span>
                </div>
              </div>
              <div class="news-list">
                {items.map((item: any, idx: number) => {
                  const hotValue = item.hot || 0;
                  return (
                    <div class={`news-item ${item.score >= 7 ? 'score-high' : item.score >= 5 ? 'score-med' : ''}`}>
                      <span class="news-idx">{idx + 1}</span>
                      <div class="news-body">
                        <a href={item.url} target="_blank" rel="noopener" class="news-title">{item.title}</a>
                        <div class="news-footer">
                          <span class="platform-tag" style={`color:${meta.color};border-color:${meta.color}20;background:${meta.color}10`}>
                            <span class="tag-icon">{meta.icon}</span>
                            {meta.label}
                          </span>
                          {hotValue > 0 && <span class="news-hot">🔥 {hotValue}</span>}
                          {item.score > 0 && <span class="news-score">SIGNAL <strong>{item.score}</strong></span>}
                        </div>
                        {item.desc && <div class="news-desc">{item.desc}</div>}
                      </div>
                    </div>
                  );
                })}
              </div>
            </section>
          );
        })}
      </div>

      <!-- History -->
      {recentDates.length > 0 && (
        <section class="section section-full">
          <div class="section-header">
            <div class="section-title">📅 History</div>
          </div>
          <div class="history-grid">
            {recentDates.map(d => (
              <a href={`/en/day/${d}`} class="history-item">
                <div>{d}</div>
                <div class="dow">{getDow(d)}</div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>

    <!-- Sidebar -->
    <aside class="sidebar">

      <!-- Platform Distribution -->
      {activePlatforms.length > 0 && (
        <div class="sidebar-widget">
          <div class="sidebar-widget-title">📊 Platform Distribution</div>
          {activePlatforms.map(p => {
            const cnt = grouped[p].length;
            const meta = PLATFORM_META[p] || { label: p, icon: '📌', color: '#94A3B8' };
            const pct = Math.round(cnt / maxPlatformCount * 100);
            return (
              <div class="dist-item">
                <div class="dist-header">
                  <span class="dist-label">{meta.icon} {meta.label}</span>
                  <span class="dist-count">{cnt}</span>
                </div>
                <div class="dist-bar">
                  <div class="dist-bar-fill" style={`width:${pct}%;background:${meta.color}`}></div>
                </div>
              </div>
            );
          })}
        </div>
      )}

      <!-- Mini Stats -->
      <div class="sidebar-widget">
        <div class="sidebar-widget-title">📊 Overview</div>
        <div class="stats-grid">
          <div class="stat-cell">
            <div class="stat-cell-value">{totalItems}</div>
            <div class="stat-cell-label">Today</div>
          </div>
          <div class="stat-cell">
            <div class="stat-cell-value">{activePlatforms.length}</div>
            <div class="stat-cell-label">Sources</div>
          </div>
          <div class="stat-cell">
            <div class="stat-cell-value">{recentDates.length}</div>
            <div class="stat-cell-label">Days</div>
          </div>
          <div class="stat-cell">
            <div class="stat-cell-value">{dayData.items.filter((i: any) => i.score >= 7).length}</div>
            <div class="stat-cell-label">High Signals</div>
          </div>
        </div>
      </div>

      <!-- Vercel Affiliate -->
      <div class="sidebar-widget">
        <a href="https://vercel.com/affiliates" target="_blank" rel="noopener" style="display:block;text-decoration:none;">
          <div class="ad-card" style="border-style:solid;padding:16px;">
            <div class="ad-label">Sponsored</div>
            <div class="ad-content">
              <strong>▲ Vercel</strong><br />
              <span style="font-size:0.85em;">Deploy your frontend apps at the edge</span>
            </div>
          </div>
        </a>
      </div>

      <!-- Trending / Top Signals -->
      <div class="sidebar-widget">
        {trending.filter((i: any) => i.hot > 0).length > 0 ? (
          <>
            <div class="sidebar-widget-title">🔥 Trending Now</div>
            {trending.map((item, idx) => (
              <div class="trending-item">
                <span class={`trending-rank ${idx < 3 ? 'top-3' : ''}`}>{idx + 1}</span>
                <a href={item.url} target="_blank" rel="noopener" class="trending-title">{item.title}</a>
              </div>
            ))}
          </>
        ) : (
          <>
            <div class="sidebar-widget-title">📡 Top Signals</div>
            {featured.map((item, idx) => {
              const meta = PLATFORM_META[item.platform] || { label: item.platform_label || item.platform, icon: '📌', color: '#94A3B8' };
              return (
                <div class="signal-item">
                  <span class={`signal-badge ${item.score >= 8 ? 'high' : 'med'}`}>{item.score}</span>
                  <div>
                    <span class="signal-source" style={`color:${meta.color}`}>{meta.icon} {meta.label}</span>
                    <a href={item.url} target="_blank" rel="noopener" class="signal-title">{item.title}</a>
                  </div>
                </div>
              );
            })}
          </>
        )}
      </div>

    </aside>
  </div>

  <div class="footer">
    📡 Powered by Zhipu GLM-5 · DOUZI LABS Daily Intel<br />
    Daily auto-collection · AI-scored · Native ads
  </div>

</div>

<button id="backToTop" class="back-to-top" aria-label="Back to top">↑</button>

</BaseLayout>

<style>
  html { scroll-behavior: smooth; }

  .featured-hero {
    display: flex;
    flex-direction: column;
    padding: 16px 20px;
  }
  .hero-entry {
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
  }
  .hero-entry:last-child {
    border-bottom: none;
  }
  .hero-entry-rank {
    font-family: var(--font-mono);
    font-size: 0.6em;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 4px;
    letter-spacing: 0.5px;
  }
  .hero-entry-title {
    font-size: 0.88em;
    font-weight: 700;
    color: var(--text-h);
    line-height: 1.4;
    margin-bottom: 6px;
  }
  .hero-entry-title a:hover {
    color: var(--accent);
  }
  .hero-entry-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
  }
</style>

<script>
  const themeBtn = document.getElementById('themeToggle');
  if (themeBtn) {
    let theme = localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-theme', theme);
    themeBtn.textContent = theme === 'dark' ? '☀️' : '🌙';
    themeBtn.addEventListener('click', () => {
      theme = theme === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
      themeBtn.textContent = theme === 'dark' ? '☀️' : '🌙';
    });
  }

  const nav = document.getElementById('sectionNav');
  if (nav) {
    const links = nav.querySelectorAll('a');
    const sections = Array.from(links).map(link => {
      const id = link.getAttribute('data-target');
      return id ? document.getElementById(id) : null;
    }).filter(Boolean);

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          links.forEach(link => {
            link.classList.toggle('active', link.getAttribute('data-target') === id);
          });
        }
      });
    }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });

    sections.forEach(section => {
      if (section) observer.observe(section);
    });
  }

  const backBtn = document.getElementById('backToTop');
  if (backBtn) {
    window.addEventListener('scroll', () => {
      backBtn.classList.toggle('visible', window.scrollY > 400);
    });
    backBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

</script>
