---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PLATFORMS, PLATFORMS_EN, getDayData, getAllDates } from '../../utils/data.ts';
import fs from 'fs';
import path from 'path';

const DATA_ROOT = path.join(process.cwd(), 'src/data/rewrite/en');
const HEALTH_PATH = path.join(process.cwd(), 'src/data/rewrite/source-health.json');

let totalItems = 0;
let platformDist: Record<string, number> = {};
let dateCount = 0;

if (fs.existsSync(DATA_ROOT)) {
  const files = fs.readdirSync(DATA_ROOT).filter(f => f.endsWith('.json') && f !== 'source-health.json');
  dateCount = files.length;
  files.forEach(f => {
    const data = JSON.parse(fs.readFileSync(path.join(DATA_ROOT, f), 'utf-8'));
    totalItems += data.items.length;
    data.items.forEach((it: any) => {
      const p = it.platform || 'other';
      platformDist[p] = (platformDist[p] || 0) + 1;
    });
  });
}

const sortedPlatforms = Object.entries(platformDist)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12);

const maxCount = sortedPlatforms[0]?.[1] || 1;

// Source health data
let healthSources: any[] = [];
let healthDate = '';
try {
  const healthRaw = JSON.parse(fs.readFileSync(HEALTH_PATH, 'utf-8'));
  healthDate = healthRaw.date || '';
  healthSources = healthRaw.sources || [];
} catch {}

const SOURCE_LABELS: Record<string, { label: string; icon: string }> = {
  news_aggregator: { label: 'News Aggregator', icon: '📡' },
  weibo: { label: 'Weibo', icon: '🔥' },
  douyin: { label: 'Douyin', icon: '🎵' },
  reddit: { label: 'Reddit', icon: '💬' },
  rss: { label: 'RSS Feeds', icon: '📰' },
};
---

<BaseLayout title="📊 Data Stats · INTEL.SYS" lang="en">
<div class="page">

  <header class="header">
    <div class="header-brand">
      <div class="header-logo">INTEL<span>.SYS</span></div>
    </div>
    <div class="header-meta">
      <span class="count-badge">{totalItems.toLocaleString()} items / {dateCount} days</span>
    </div>
    <div class="header-actions">
      <a href="/en/" class="lang-btn">← Home</a>
      <a href="/en/archive" class="lang-btn">📁 Archive</a>
      <a href="/" class="lang-btn">中文</a>
      <button id="themeToggle" class="theme-btn" aria-label="Toggle theme">🌙</button>
    </div>
  </header>

  <div style="margin-bottom:40px;">
    <h1 style="font-size:1.4em;font-weight:800;color:var(--text-h);display:flex;align-items:center;gap:8px;">📊 Data Stats</h1>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:16px;margin-bottom:40px;">
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;text-align:center;">
      <div style="font-size:2em;font-weight:800;color:var(--text-h);font-family:var(--font-mono);">{totalItems.toLocaleString()}</div>
      <div style="font-size:0.8em;color:var(--text-m);margin-top:6px;">Total Items</div>
    </div>
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;text-align:center;">
      <div style="font-size:2em;font-weight:800;color:var(--text-h);font-family:var(--font-mono);">{dateCount}</div>
      <div style="font-size:0.8em;color:var(--text-m);margin-top:6px;">Days Covered</div>
    </div>
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;text-align:center;">
      <div style="font-size:2em;font-weight:800;color:var(--text-h);font-family:var(--font-mono);">{Object.keys(platformDist).length}</div>
      <div style="font-size:0.8em;color:var(--text-m);margin-top:6px;">Sources</div>
    </div>
  </div>

  <div class="section">
    <div class="section-header">
      <div class="section-title">📊 Platform Distribution</div>
    </div>
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:20px 24px;">
      {sortedPlatforms.map(([p, cnt]) => {
        const meta = PLATFORMS[p] || { label: p, color: '#94a3b8', icon: '📌' };
        const label = PLATFORMS_EN[p] || meta.label;
        const pct = Math.round(cnt / maxCount * 100);
        return (
          <div style="display:flex;align-items:center;gap:16px;padding:12px 0;border-bottom:1px solid var(--border);">
            <div style="min-width:120px;font-size:0.85em;font-weight:600;color:var(--text-p);display:flex;align-items:center;gap:6px;">
              <span>{meta.icon}</span>
              <span>{label}</span>
            </div>
            <div style="flex:1;height:8px;background:var(--bg);border-radius:4px;overflow:hidden;">
              <div style={`height:100%;width:${pct}%;background:${meta.color};border-radius:4px;`}></div>
            </div>
            <div style="min-width:50px;text-align:right;font-family:var(--font-mono);font-size:0.8em;font-weight:600;color:var(--text-m);">{cnt.toLocaleString()}</div>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Source Health Monitoring -->
  {healthSources.length > 0 && (
    <div class="section" style="margin-top:32px;">
      <div class="section-header">
        <div class="section-title">💚 Source Health</div>
        <span class="section-count" style="font-size:0.72em;color:var(--text-m);">{healthDate || ''}</span>
      </div>
      <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:20px 24px;">
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:12px;">
          {healthSources.map((s: any) => {
            const meta = SOURCE_LABELS[s.source] || { label: s.source, icon: '📌' };
            const isOk = s.status === 'success';
            const isError = s.status === 'error';
            const statusIcon = isOk ? '✅' : isError ? '❌' : '⚠️';
            const statusColor = isOk ? '#22C55E' : isError ? '#EF4444' : '#F59E0B';
            const statusLabel = isOk ? 'Healthy' : isError ? 'Error' : 'Warning';
            return (
              <div style="background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:14px 16px;display:flex;flex-direction:column;gap:6px;">
                <div style="display:flex;align-items:center;justify-content:space-between;">
                  <span style="font-size:0.85em;font-weight:600;color:var(--text-h);display:flex;align-items:center;gap:6px;">
                    <span>{meta.icon}</span>
                    <span>{meta.label}</span>
                  </span>
                  <span style={`font-size:0.72em;font-weight:600;padding:2px 8px;border-radius:4px;background:${statusColor}15;color:${statusColor};`}>
                    {statusIcon} {statusLabel}
                  </span>
                </div>
                <div style="display:flex;gap:12px;font-size:0.72em;color:var(--text-m);">
                  <span>📦 {s.items_found} items</span>
                  {s.duration_ms > 0 && <span>⏱ {Math.round(s.duration_ms / 1000)}s</span>}
                </div>
                {s.error_message && (
                  <div style="font-size:0.7em;color:#EF4444;padding:6px 8px;background:rgba(239,68,68,0.08);border-radius:6px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                    {s.error_message}
                  </div>
                )}
              </div>
            );
          })}
        </div>
      </div>
    </div>
  )}

  <!-- Footer -->
  <div class="footer">
    📡 INTEL.SYS · Statistics
    <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border);display:flex;flex-wrap:wrap;justify-content:center;gap:8px 16px;font-size:0.85em;">
      <span style="font-weight:700;color:var(--text-h);">🌐 Zhineng Ecosystem</span>
      <a href="https://news.zhinengtech.dpdns.org" target="_blank" rel="noopener" style="color:var(--text-p);text-decoration:none;transition:color 0.12s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-p)'">Zhineng News</a>
      <a href="https://zhinengtools.pages.dev" target="_blank" rel="noopener" style="color:var(--text-p);text-decoration:none;transition:color 0.12s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-p)'">Zhineng Tools</a>
      <a href="https://github.com/weixin008" target="_blank" rel="noopener" style="color:var(--text-p);text-decoration:none;transition:color 0.12s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-p)'">GitHub</a>
      <span style="color:var(--text-m);">💬 WeChat: 豆子实验室</span>
    </div>
  </div>

</div>

<script>
  const btn = document.getElementById('themeToggle');
  if (btn) {
    let theme = localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-theme', theme);
    btn.textContent = theme === 'dark' ? '☀️' : '🌙';
    btn.addEventListener('click', () => {
      theme = theme === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
      btn.textContent = theme === 'dark' ? '☀️' : '🌙';
    });
  }
</script>
</BaseLayout>
