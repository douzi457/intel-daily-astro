---
// 日报详情页 — 基于已有的 JSON 数据，AI 焦点 + 高分条目整合展示
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getDayData, getAllDates } from '../../utils/data.ts';
import { getPlatformMeta } from '../../lib/constants';
import type { IntelItem, FocusData } from '../../lib/types';

export async function getStaticPaths() {
  const dates = getAllDates('zh');
  return dates.map(d => ({ params: { date: d } }));
}

const { date } = Astro.params;
const dayData = getDayData(date, 'zh');
const items: IntelItem[] = dayData.items;

// 加载焦点数据
let focusData: FocusData | null = null;
try {
  const mod = await import('../../data/rewrite/today-focus.json');
  focusData = mod.default as FocusData;
} catch {}

// 按评分排序
const sorted = [...items].sort((a, b) => (b.score || 0) - (a.score || 0));
const highScore = sorted.filter(i => i.score >= 7);
const medScore = sorted.filter(i => i.score >= 5 && i.score < 7);
const stats = {
  total: items.length,
  highScore: highScore.length,
  medScore: medScore.length,
  platforms: new Set(items.map(i => i.platform)).size,
};

// 日期导航
const allDates = getAllDates('zh');
const dateIdx = allDates.indexOf(date);
const prevDate = dateIdx < allDates.length - 1 ? allDates[dateIdx + 1] : null;
const nextDate = dateIdx > 0 ? allDates[dateIdx - 1] : null;
---

<BaseLayout title={`日报 | ${date}`} lang="zh-CN">
<div class="page">
  <Header mode="day" date={date} totalItems={stats.total} />

  <!-- 日期导航 -->
  <nav class="date-nav">
    {prevDate && <a href={`/daily/${prevDate}`} class="date-nav-link">← {prevDate}</a>}
    <span class="date-nav-current">{date}</span>
    {nextDate && <a href={`/daily/${nextDate}`} class="date-nav-link">{nextDate} →</a>}
  </nav>

  <!-- 统计横条 -->
  <div class="stats-bar">
    <div class="stats-item">
      <span class="stats-value">{stats.total}</span>
      <span class="stats-label">情报</span>
    </div>
    <div class="stats-divider"></div>
    <div class="stats-item highlight">
      <span class="stats-value">{stats.highScore}</span>
      <span class="stats-label">高价值</span>
    </div>
    <div class="stats-divider"></div>
    <div class="stats-item">
      <span class="stats-value">{stats.medScore}</span>
      <span class="stats-label">中等</span>
    </div>
    <div class="stats-divider"></div>
    <div class="stats-item">
      <span class="stats-value">{stats.platforms}</span>
      <span class="stats-label">平台</span>
    </div>
  </div>

  <!-- 编辑手记（来自 Focus） -->
  {focusData && (focusData.summary || focusData.trendAnalysis) && (
    <section class="editor-note">
      {focusData.summary && <div class="editor-summary">{focusData.summary}</div>}
      {focusData.trendAnalysis && (
        <div class="editor-analysis">
          <span class="editor-badge">📊 编辑手记</span>
          <p>{focusData.trendAnalysis}</p>
        </div>
      )}
      {focusData.trends && focusData.trends.length > 0 && (
        <div class="trend-tags">
          {focusData.trends.map(t => <span class="trend-tag">{t}</span>)}
        </div>
      )}
    </section>
  )}

  <!-- 高价值信号 -->
  {highScore.length > 0 && (
    <section class="report-section">
      <h2 class="section-heading">
        <span class="heading-accent"></span>
        高价值信号
        <span class="heading-count">{highScore.length}</span>
      </h2>
      <div class="signal-list">
        {highScore.map((item, idx) => {
          const meta = getPlatformMeta(item.platform, 'zh');
          return (
            <article class="signal-card score-high">
              <div class="signal-rank">#{idx + 1}</div>
              <div class="signal-content">
                <a href={item.url} target="_blank" rel="noopener" class="signal-title">{item.title}</a>
                {item.desc && <p class="signal-desc">{item.desc}</p>}
                <div class="signal-meta">
                  <span class="signal-platform" style={`color:${meta.color}`}>{meta.icon} {meta.label}</span>
                  <span class="signal-score">信号 <strong>{item.score}</strong>/10</span>
                  {(item.cross_sources || 0) >= 3 && <span class="signal-cross">🌐 多源确认</span>}
                  {item.category && <span class="signal-category">{item.category}</span>}
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </section>
  )}

  <!-- 中等信号 -->
  {medScore.length > 0 && (
    <section class="report-section">
      <h2 class="section-heading">
        <span class="heading-accent secondary"></span>
        值得关注
        <span class="heading-count">{medScore.length}</span>
      </h2>
      <div class="signal-list">
        {medScore.map((item, idx) => {
          const meta = getPlatformMeta(item.platform, 'zh');
          return (
            <article class="signal-card score-med">
              <div class="signal-rank">{idx + 1}</div>
              <div class="signal-content">
                <a href={item.url} target="_blank" rel="noopener" class="signal-title">{item.title}</a>
                {item.desc && <p class="signal-desc">{item.desc}</p>}
                <div class="signal-meta">
                  <span class="signal-platform" style={`color:${meta.color}`}>{meta.icon} {meta.label}</span>
                  <span class="signal-score">信号 <strong>{item.score}</strong>/10</span>
                  {item.category && <span class="signal-category">{item.category}</span>}
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </section>
  )}

  {items.length === 0 && (
    <div class="empty-state">
      <div class="empty-icon">📡</div>
      <div class="empty-title">暂无数据</div>
      <div class="empty-desc">该日期尚无采集数据</div>
    </div>
  )}

  <Footer />
</div>
</BaseLayout>

<style>
.page {
  max-width: 780px;
  margin: 0 auto;
  padding: 32px 24px 60px;
}

/* 日期导航 */
.date-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
  padding: 12px 16px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
}

.date-nav-link {
  font-size: 0.82em;
  color: var(--text-m);
  text-decoration: none;
  padding: 4px 12px;
  border-radius: 8px;
  transition: all 0.15s;
}

.date-nav-link:hover {
  color: var(--accent);
  background: var(--accent-glow);
}

.date-nav-current {
  font-family: var(--font-mono);
  font-size: 0.9em;
  font-weight: 700;
  color: var(--text-h);
}

/* 统计横条 */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  padding: 16px 24px;
  margin-bottom: 24px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 14px;
}

.stats-item {
  text-align: center;
  padding: 0 24px;
}

.stats-item.highlight .stats-value {
  color: var(--accent);
}

.stats-value {
  display: block;
  font-family: var(--font-mono);
  font-size: 1.3em;
  font-weight: 800;
  color: var(--text-h);
  font-variant-numeric: tabular-nums;
}

.stats-label {
  display: block;
  font-size: 0.68em;
  color: var(--text-m);
  margin-top: 2px;
}

.stats-divider {
  width: 1px;
  height: 28px;
  background: var(--border);
}

/* 编辑手记 */
.editor-note {
  margin-bottom: 28px;
  padding: 24px;
  background: linear-gradient(160deg, var(--accent-glow), color-mix(in srgb, var(--accent) 4%, transparent), var(--bg-card));
  border: 1px solid color-mix(in srgb, var(--accent) 15%, transparent);
  border-radius: 16px;
}

.editor-summary {
  font-size: 1.05em;
  font-weight: 700;
  color: var(--text-h);
  line-height: 1.5;
  margin-bottom: 14px;
}

.editor-analysis {
  margin-bottom: 14px;
}

.editor-badge {
  display: inline-block;
  font-size: 0.72em;
  font-weight: 700;
  color: var(--accent);
  background: color-mix(in srgb, var(--accent) 10%, transparent);
  border-radius: 6px;
  padding: 3px 10px;
  margin-bottom: 8px;
}

.editor-analysis p {
  font-size: 0.88em;
  color: var(--text-p);
  line-height: 1.75;
  padding-left: 12px;
  border-left: 3px solid var(--accent);
}

.trend-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.trend-tag {
  font-size: 0.75em;
  padding: 5px 14px;
  background: var(--bg);
  border: 1px solid color-mix(in srgb, var(--accent) 15%, transparent);
  border-radius: 20px;
  color: var(--accent);
  font-weight: 600;
}

/* 报告区块 */
.report-section {
  margin-bottom: 36px;
}

.section-heading {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 1.1em;
  font-weight: 700;
  color: var(--text-h);
  margin-bottom: 16px;
}

.heading-accent {
  width: 4px;
  height: 20px;
  background: var(--accent);
  border-radius: 2px;
}

.heading-accent.secondary {
  background: #fbbf24;
}

.heading-count {
  font-size: 0.7em;
  font-weight: 500;
  color: var(--text-m);
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 2px 10px;
  font-family: var(--font-mono);
}

/* 信号卡片 */
.signal-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.signal-card {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 16px 20px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: var(--bg-card);
  transition: all 0.15s;
}

.signal-card:hover {
  border-color: color-mix(in srgb, var(--accent) 25%, transparent);
  background: var(--bg-hover);
}

.signal-card.score-high {
  border-left: 3px solid var(--accent);
  background: linear-gradient(90deg, var(--accent-glow), transparent);
}

.signal-card.score-med {
  border-left: 3px solid #fbbf24;
}

.signal-rank {
  font-family: var(--font-mono);
  font-size: 0.75em;
  font-weight: 700;
  color: var(--accent);
  min-width: 28px;
  padding-top: 2px;
  flex-shrink: 0;
}

.signal-card.score-med .signal-rank {
  color: #fbbf24;
}

.signal-content {
  flex: 1;
  min-width: 0;
}

.signal-title {
  font-size: 0.95em;
  font-weight: 650;
  color: var(--text-h);
  line-height: 1.5;
  display: block;
  text-decoration: none;
  transition: color 0.12s;
}

.signal-title:hover {
  color: var(--accent);
}

.signal-desc {
  font-size: 0.82em;
  color: var(--text-m);
  line-height: 1.55;
  margin: 6px 0 0;
}

.signal-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10px;
  margin-top: 8px;
  font-size: 0.75em;
}

.signal-platform {
  font-weight: 600;
}

.signal-score {
  font-family: var(--font-mono);
  color: var(--text-m);
  font-size: 0.92em;
}

.signal-score strong {
  color: var(--accent);
  font-weight: 700;
}

.signal-cross {
  font-size: 0.88em;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 20px;
  background: rgba(34, 197, 94, 0.1);
  color: #22C55E;
  border: 1px solid rgba(34, 197, 94, 0.2);
}

.signal-category {
  color: var(--text-m);
  background: var(--bg);
  padding: 2px 8px;
  border-radius: 6px;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60px 24px;
}

.empty-icon { font-size: 2.5em; margin-bottom: 12px; }
.empty-title { font-size: 1.1em; font-weight: 700; color: var(--text-h); margin-bottom: 6px; }
.empty-desc { font-size: 0.85em; color: var(--text-m); }

@media (max-width: 640px) {
  .page { padding: 20px 16px 40px; }
  .stats-bar { padding: 14px 12px; }
  .stats-item { padding: 0 14px; }
  .stats-value { font-size: 1.1em; }
  .signal-card { padding: 12px 14px; }
  .signal-title { font-size: 0.88em; }
}
</style>
