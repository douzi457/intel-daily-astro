---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllDates } from '../utils/data.ts';
import CalendarWidget from '../components/CalendarWidget.astro';

const dates = getAllDates('zh');
---

<BaseLayout title="📁 历史归档 · INTEL.SYS">
<div class="page">

  <header class="header">
    <div class="header-brand">
      <div class="header-logo">INTEL<span>.SYS</span></div>
    </div>
    <div class="header-meta">
      <span class="count-badge">{dates.length} 天数据</span>
    </div>
    <div class="header-actions">
      <a href="/" class="lang-btn">← 首页</a>
      <a href="/stats" class="lang-btn">📊 统计</a>
      <button id="themeToggle" class="theme-btn" aria-label="切换主题">🌙</button>
    </div>
  </header>

  <div style="margin-bottom:40px;">
    <h1 style="font-size:1.4em;font-weight:800;color:var(--text-h);display:flex;align-items:center;gap:8px;">📁 历史归档</h1>
  </div>

  <CalendarWidget dates={dates} basePath="/day/" locale="zh" />

  <div class="footer" style="margin-top:40px;">📡 INTEL.SYS · 历史归档</div>

</div>

<script>
  const btn = document.getElementById('themeToggle');
  if (btn) {
    let theme = localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-theme', theme);
    btn.textContent = theme === 'dark' ? '☀️' : '🌙';
    btn.addEventListener('click', () => {
      theme = theme === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
      btn.textContent = theme === 'dark' ? '☀️' : '🌙';
    });
  }
</script>
</BaseLayout>
