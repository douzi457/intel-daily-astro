---
// 归档页 — 使用共享组件
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getAllDates } from '../utils/data.ts';
import CalendarWidget from '../components/CalendarWidget.astro';

const dates = getAllDates('zh');
---

<BaseLayout title="📁 历史归档 · 豆子实验室">
<div class="page">
  <Header mode="archive" />

  <div style="margin-bottom:40px;">
    <h1 style="font-size:1.4em;font-weight:800;color:var(--text-h);display:flex;align-items:center;gap:8px;">📁 历史归档</h1>
    <p style="font-size:0.82em;color:var(--text-m);margin-top:6px;">共 {dates.length} 天数据</p>
  </div>

  <CalendarWidget dates={dates} basePath="/day/" locale="zh" />

  <Footer />
</div>
</BaseLayout>
