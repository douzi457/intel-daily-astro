---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllDates } from '../utils/data.ts';

const dates = getAllDates('zh');

const dowLabels = ['周一','周二','周三','周四','周五','周六','周日'];
function getDow(d: string) {
  const idx = new Date(d + 'T00:00:00').getDay();
  return dowLabels[idx === 0 ? 6 : idx - 1];
}
---

<BaseLayout title="📁 历史归档 · INTEL.SYS">
<div class="layout">

  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-text">INTEL<span>.SYS</span></div>
      <div class="logo-sub">Superpowers · 情报站</div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section">
        <div class="nav-section-title">导航</div>
        <a href="/" class="nav-item"><span class="icon">📡</span><span class="label">首页</span></a>
        <a href="/archive" class="nav-item active"><span class="icon">📁</span><span class="label">归档</span></a>
        <a href="/stats" class="nav-item"><span class="icon">📊</span><span class="label">统计</span></a>
      </div>
      <div class="nav-section">
        <div class="nav-section-title">最近日报</div>
        {dates.slice(0, 8).map(d => (
          <a href={`/day/${d}`} class="nav-item-recent"><span>{d}</span></a>
        ))}
      </div>
    </nav>
    <div class="sidebar-footer">自动生成 · 每2小时更新</div>
  </aside>

  <main class="main">
    <div class="container">
      <div class="topbar">
        <h1 class="topbar-title">📁 历史<span>归档</span></h1>
        <span class="topbar-meta">{dates.length} 天历史数据</span>
      </div>

      <div class="archive-grid">
        {dates.map(d => (
          <div class="archive-item">
            <a href={`/day/${d}`}>
              {d}
              <span class="dow">{getDow(d)}</span>
            </a>
          </div>
        ))}
      </div>

      <footer>📡 INTEL.SYS · 历史归档</footer>
    </div>
  </main>

</div>
</BaseLayout>
