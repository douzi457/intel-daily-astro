---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllDates } from '../utils/data.ts';

const dates = getAllDates('zh');

const dowLabels = ['周一','周二','周三','周四','周五','周六','周日'];
function getDow(d: string) {
  const idx = new Date(d + 'T00:00:00').getDay();
  return dowLabels[idx === 0 ? 6 : idx - 1];
}
---

<BaseLayout title="📁 历史归档 · INTEL.SYS">
<div class="page">

  <header class="header">
    <div class="header-brand">
      <div class="header-logo">INTEL<span>.SYS</span></div>
    </div>
    <div class="header-meta">
      <span class="count-badge">{dates.length} 天数据</span>
    </div>
    <div class="header-actions">
      <a href="/" class="lang-btn">← 首页</a>
      <a href="/stats" class="lang-btn">📊 统计</a>
      <button id="themeToggle" class="theme-btn" aria-label="切换主题">🌙</button>
    </div>
  </header>

  <div style="margin-bottom:40px;">
    <h1 style="font-size:1.4em;font-weight:800;color:var(--text-h);display:flex;align-items:center;gap:8px;">📁 历史归档</h1>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px;">
    {dates.map(d => (
      <a href={`/day/${d}`} class="history-item">
        <div>{d}</div>
        <div class="dow">{getDow(d)}</div>
      </a>
    ))}
  </div>

  <div class="footer">📡 INTEL.SYS · 历史归档</div>

</div>

<script>
  const btn = document.getElementById('themeToggle');
  if (btn) {
    let theme = localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-theme', theme);
    btn.textContent = theme === 'dark' ? '☀️' : '🌙';
    btn.addEventListener('click', () => {
      theme = theme === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
      btn.textContent = theme === 'dark' ? '☀️' : '🌙';
    });
  }
</script>
</BaseLayout>
