  align-items: center;
  justify-content: center;
  border-radius: 10px;
  font-size: 0.7em;
  font-weight: 700;
  font-family: var(--font-mono);
  color: #fff;
  margin-top: 2px;
}

.pick-item-body {
  flex: 1;
  min-width: 0;
}

.pick-item-title {
  font-size: 0.88em;
  font-weight: 600;
  color: var(--text-h);
  line-height: 1.45;
  margin-bottom: 6px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.pick-item:hover .pick-item-title {
