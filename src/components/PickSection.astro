}

.pick-item-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
  font-size: 0.72em;
  color: var(--text-m);
  margin-bottom: 8px;
}

.pick-item-source {
  color: var(--text-m);
  font-family: var(--font-mono);
  font-size: 0.9em;
}

.pick-item-heat {
  color: #e74c3c;
  font-weight: 600;
}

.pick-item-summary {
  font-size: 0.78em;
  color: var(--text-p);
  line-height: 1.55;
  padding: 8px 12px;
  background: var(--bg);
  border-left: 2px solid var(--accent);
  border-radius: 0 8px 8px 0;
}

/* ════════════════════════ 响应式 ════════════════════════ */
@media (max-width: 640px) {
  .hero-bento {
    padding: 16px 18px;
  }
  .hero-bento-title {
    font-size: 1em;
  }
  .hero-main-card {
    flex-direction: column;
