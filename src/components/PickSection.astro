---
// 每日精选 — 来自 dashboard_v4 的推荐 + 热搜 Hero
import type { V4DailyData, V4RecommendItem } from '../lib/types';

interface Props {
  data: V4DailyData | null;
}

const { data } = Astro.props;

const CATEGORY_META: Record<string, { icon: string; desc: string }> = {
  'AI/大模型': { icon: '🤖', desc: 'AI 前沿、大模型、智能体' },
  '数码/硬件': { icon: '📱', desc: '手机、芯片、数码产品' },
  '开源/工具': { icon: '🐙', desc: 'GitHub 开源项目、开发工具' },
  '科技热点': { icon: '🔥', desc: '今日最热的科技话题' },
  '财经/商业': { icon: '📈', desc: '科技财经、商业动态' },
  '财经商业': { icon: '📈', desc: '科技财经、商业动态' },
};

const CATEGORY_ORDER = ['AI/大模型', '数码/硬件', '开源/工具', '科技热点', '财经/商业', '财经商业'];

if (!data || !data.recommendations) return null;

const activeCats = CATEGORY_ORDER.filter(cat => (data.recommendations[cat]?.length || 0) > 0);
if (activeCats.length === 0) return null;

// ── 热搜 Top 5（跨分类按 score 排序） ──
interface HeroItem extends V4RecommendItem {
  category: string;
  catIcon: string;
}

const allItems: HeroItem[] = [];
for (const cat of activeCats) {
  const meta = CATEGORY_META[cat] || { icon: '📌', desc: '' };
  for (const item of data.recommendations[cat] || []) {
    allItems.push({ ...item, category: cat, catIcon: meta.icon });
  }
}
const sortedTop = allItems.sort((a, b) => b.score - a.score);
const topItems = sortedTop.slice(0, 5);
const heroItem = topItems[0];
const sideItems = topItems.slice(1);

// ── Hero URL 集合，用于分类去重 ──
const heroUrls = new Set(topItems.map(i => i.url));

// ── 评分色阶 ──
function scoreColor(s: number): string {
  if (s >= 8.5) return '#ef4444';
  if (s >= 7) return '#f59e0b';
  if (s >= 6) return '#10b981';
  return '#6b7280';
}
function scoreBg(s: number): string {
  if (s >= 8.5) return 'rgba(239,68,68,0.15)';
  if (s >= 7) return 'rgba(245,158,11,0.15)';
  if (s >= 6) return 'rgba(16,185,129,0.15)';
  return 'rgba(107,114,128,0.10)';
}
function truncate(text: string, max: number): string {
  if (!text || text.length <= max) return text || '';
  return text.slice(0, max) + '…';
}

// ── 垃圾摘要检测（UI 文本、导航文字等） ──
const GARBAGE_PATTERNS = [
  /关闭.*此主题.*帖子.*(?:添加到|邮件|摘要|提要)/,
  /添加到您的每日电子邮件摘要/,
  /此主题的[^。]*帖子将[^。]*添加到/,
  /查看所有[^。]*关闭/,
  /查看全部(?:游戏|娱乐|新闻|科技|体育|财经)/,
  /Follow.*关注/,
  /Skip to content|Skip to main content|Navigation Menu/,
  /Toggle navigation|Sign in|Log in|Subscribe/,
  /Theme\s*(?:Light|Dark|System)|Privacy.*Cookies/,
  /此主题的[^。]*帖子/,
];
function isGarbageSummary(text: string | undefined | null): boolean {
  if (!text || text.length < 10) return true;
  // 检查是否大部分是垃圾
  let garbageCount = 0;
  for (const p of GARBAGE_PATTERNS) {
    const matches = text.match(p);
    if (matches) garbageCount += matches[0].length;
  }
  // 如果垃圾字符超过 40%，判定为垃圾摘要
  return garbageCount > text.length * 0.4;
}
function cleanSummary(text: string | undefined | null): string | null {
  if (!text || text.length < 10 || isGarbageSummary(text)) return null;
  return text;
}
// ── 计算最热的5个分类 ──
const catStats = activeCats
  .map(cat => ({
    name: cat,
    meta: CATEGORY_META[cat] || { icon: '📌', desc: '' },
    count: (data.recommendations[cat] || []).length,
    avgScore: (data.recommendations[cat] || []).reduce((a, i) => a + i.score, 0) / Math.max((data.recommendations[cat] || []).length, 1),
  }))
  .sort((a, b) => b.avgScore - a.avgScore);
---

<section class="pick-section">
  <!-- ═══════════════════ 热搜 Hero ═══════════════════ -->
  {topItems.length > 0 && (
    <div class="hero-bento">
      <div class="hero-bento-header">
        <h2 class="hero-bento-title">🔥 今日热搜</h2>
        <span class="hero-bento-sub">{data.total_sources} 个信息源 · {Math.round(sortedTop.reduce((a,i) => a + i.score, 0) / sortedTop.length * 10) / 10} 平均分</span>
      </div>

      <div class="hero-bento-grid">
        <!-- ═══ 主卡 ═══ -->
        <a href={heroItem.url || '#'} target="_blank" rel="noopener" class="hero-main-card">
          <div class="hero-main-score" style={`background:${scoreColor(heroItem.score)}`}>{heroItem.score}</div>
          <div class="hero-main-body">
            <div class="hero-main-rank">🏆 今日最佳</div>
            <h3 class="hero-main-title">{heroItem.title}</h3>
            <div class="hero-main-meta">
              <span class="hero-main-source">{heroItem.source}</span>
              {heroItem.heat && <span class="hero-main-heat">🔥 {heroItem.heat}</span>}
            </div>
            {cleanSummary(heroItem.summary) && <p class="hero-main-summary">{truncate(cleanSummary(heroItem.summary)!, 120)}</p>}
          </div>
        </a>

        <!-- ═══ 边卡 2×2 ═══ -->
        {sideItems.length > 0 && (
          <div class="hero-side-grid">
            {sideItems.map((item) => (
              <a href={item.url || '#'} target="_blank" rel="noopener" class="hero-side-card">
                <div class="hero-side-score" style={`background:${scoreColor(item.score)}`}>{item.score}</div>
                <div class="hero-side-body">
                  <div class="hero-side-title">{item.title}</div>
                  <div class="hero-side-meta">
                    <span>{item.source}</span>
                    {item.heat && <span class="hero-side-heat">🔥 {item.heat}</span>}
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  )}

  <!-- ═══════════════════ 分类精选 ═══════════════════ -->
  <div class="pick-masthead">
    <h2 class="pick-title">📊 今日精选推荐</h2>
    <div class="pick-cat-stats">
      {catStats.slice(0, 5).map(cs => (
        <span class="pick-cat-stat" style={`--stat-color:${scoreColor(cs.avgScore)}`}>
          {cs.meta.icon} {cs.name} <em>{Math.round(cs.avgScore * 10) / 10}</em>
        </span>
      ))}
    </div>
  </div>

  <div class="pick-grid">
    {activeCats.map((cat) => {
      const items = (data.recommendations[cat] as V4RecommendItem[]).filter(item => !heroUrls.has(item.url));
      if (items.length === 0) return null;
      const meta = CATEGORY_META[cat] || { icon: '📌', desc: '' };
      return (
        <div class="pick-category">
          <div class="pick-cat-header">
            <span class="pick-cat-icon">{meta.icon}</span>
            <div class="pick-cat-info">
              <h3 class="pick-cat-name">{cat}</h3>
              {meta.desc && <span class="pick-cat-desc">{meta.desc}</span>}
            </div>
            <span class="pick-cat-count">{items.length} 条</span>
          </div>

          <div class="pick-items">
            {items.map((item) => (
              <a href={item.url || '#'} target="_blank" rel="noopener" class={`pick-item ${item.score >= 8.5 ? 'score-elite' : item.score >= 7 ? 'score-great' : ''}`}>
                <div class="pick-item-score" style={`background:${scoreColor(item.score)}; box-shadow: 0 0 6px ${scoreColor(item.score)}40`}>
                  {item.score}
                </div>
                <div class="pick-item-body">
                  <div class="pick-item-title">{item.title}</div>
                  <div class="pick-item-meta">
                    <span class="pick-item-source">{item.source}</span>
                    {item.heat && <span class="pick-item-heat">🔥 {item.heat}</span>}
                  </div>
                  {cleanSummary(item.summary) && <div class="pick-item-summary">{truncate(cleanSummary(item.summary)!, 180)}</div>}
                </div>
              </a>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
/* ──────────────────────────────────────────────
   每日精选 + 热搜 Hero 组件样式
   ────────────────────────────────────────────── */

.pick-section {
  margin-bottom: 32px;
}

/* ════════════════════════ 热搜 Hero ════════════════════════ */

.hero-bento {
  background: linear-gradient(160deg, var(--accent-glow), color-mix(in srgb, var(--accent) 5%, transparent), var(--bg-card));
  border: 1px solid color-mix(in srgb, var(--accent) 10%, transparent);
  border-radius: 20px;
  padding: 24px 28px;
  margin-bottom: 28px;
  position: relative;
  overflow: hidden;
}

.hero-bento::after {
  content: '';
  position: absolute;
  top: -25%;
  right: -8%;
  width: 280px;
  height: 280px;
  background: radial-gradient(circle, color-mix(in srgb, var(--accent) 10%, transparent) 0%, transparent 70%);
  pointer-events: none;
}

.hero-bento-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 18px;
  flex-wrap: wrap;
}

.hero-bento-title {
  font-size: 1.15em;
  font-weight: 800;
  color: var(--text-h);
  margin: 0;
  letter-spacing: -0.3px;
}

.hero-bento-sub {
  font-size: 0.72em;
  color: var(--text-m);
  font-weight: 500;
}

/* ── Bento Grid ── */
.hero-bento-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12px;
}

@media (min-width: 768px) {
  .hero-bento-grid {
    grid-template-columns: 2fr 1fr;
  }
}

/* ── 主卡 ── */
.hero-main-card {
  display: flex;
  gap: 16px;
  padding: 20px 24px;
  background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 8%, transparent), var(--bg-card));
  border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
  border-radius: 16px;
  text-decoration: none;
  transition: all 0.2s ease;
  position: relative;
  z-index: 1;
}

.hero-main-card:hover {
  border-color: var(--accent);
  transform: translateY(-2px);
  box-shadow: 0 8px 32px color-mix(in srgb, var(--accent) 12%, transparent);
}

.hero-main-score {
  flex-shrink: 0;
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12px;
  font-size: 1em;
  font-weight: 800;
  font-family: var(--font-mono);
  color: #fff;
  margin-top: 2px;
}

.hero-main-body {
  flex: 1;
  min-width: 0;
}

.hero-main-rank {
  font-size: 0.65em;
  font-weight: 700;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 6px;
}

.hero-main-title {
  font-size: 1.05em;
  font-weight: 800;
  color: var(--text-h);
  line-height: 1.45;
  margin-bottom: 8px;
}

.hero-main-card:hover .hero-main-title {
  color: var(--accent);
}

.hero-main-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
}

.hero-main-source {
  font-size: 0.72em;
  color: var(--text-m);
  font-family: var(--font-mono);
}

.hero-main-heat {
  font-size: 0.72em;
  color: #ef4444;
  font-weight: 600;
}

.hero-main-summary {
  font-size: 0.82em;
  color: var(--text-p);
  line-height: 1.6;
  padding: 8px 12px;
  background: var(--bg);
  border-left: 2px solid var(--accent);
  border-radius: 0 8px 8px 0;
}

/* ── 边卡 2×2 ── */
.hero-side-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 8px;
}

@media (min-width: 768px) {
  .hero-side-grid {
    grid-template-rows: 1fr 1fr;
  }
}

.hero-side-card {
  display: flex;
  gap: 10px;
  padding: 12px 14px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  text-decoration: none;
  transition: all 0.15s ease;
  position: relative;
  z-index: 1;
}

.hero-side-card:hover {
  border-color: color-mix(in srgb, var(--accent) 25%, transparent);
  transform: translateY(-1px);
  box-shadow: var(--shadow-md);
}

.hero-side-score {
  flex-shrink: 0;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  font-size: 0.68em;
  font-weight: 700;
  font-family: var(--font-mono);
  color: #fff;
  margin-top: 1px;
}

.hero-side-body {
  flex: 1;
  min-width: 0;
}

.hero-side-title {
  font-size: 0.8em;
  font-weight: 600;
  color: var(--text-h);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 4px;
}

.hero-side-card:hover .hero-side-title {
  color: var(--accent);
}

.hero-side-meta {
  font-size: 0.65em;
  color: var(--text-m);
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.hero-side-heat {
  color: #ef4444;
}

/* ════════════════════════ 分类精选 ════════════════════════ */

.pick-masthead {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 20px;
  flex-wrap: wrap;
}

.pick-title {
  font-size: 1.15em;
  font-weight: 800;
  color: var(--text-h);
  margin: 0;
  letter-spacing: -0.3px;
}

.pick-cat-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.pick-cat-stat {
  font-size: 0.68em;
  font-weight: 600;
  color: var(--text-m);
  padding: 3px 10px;
  background: var(--bg);
  border-radius: 20px;
  border: 1px solid var(--border);
}

.pick-cat-stat em {
  font-style: normal;
  color: var(--stat-color, var(--accent));
  font-family: var(--font-mono);
  font-weight: 700;
}

/* ── 分类卡片网格 ── */
.pick-grid {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.pick-category {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
  transition: border-color 0.15s, box-shadow 0.15s;
}

.pick-category:hover {
  border-color: var(--border-hover);
  box-shadow: var(--shadow-sm);
}

.pick-cat-header {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 16px 20px;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
}

.pick-cat-icon {
  font-size: 1.4em;
  flex-shrink: 0;
}

.pick-cat-info {
  flex: 1;
  min-width: 0;
}

.pick-cat-name {
  font-size: 0.95em;
  font-weight: 700;
  color: var(--text-h);
  margin: 0;
}

.pick-cat-desc {
  font-size: 0.72em;
  color: var(--text-m);
}

.pick-cat-count {
  font-family: var(--font-mono);
  font-size: 0.72em;
  font-weight: 600;
  color: var(--accent);
  background: color-mix(in srgb, var(--accent) 10%, transparent);
  padding: 4px 12px;
  border-radius: 8px;
  flex-shrink: 0;
}

/* ── 条目列表 ── */
.pick-items {
  display: flex;
  flex-direction: column;
}

.pick-item {
  display: flex;
  gap: 12px;
  padding: 14px 20px;
  text-decoration: none;
  border-bottom: 1px solid var(--border);
  transition: background 0.12s, padding-left 0.15s;
  position: relative;
}

.pick-item:last-child {
  border-bottom: none;
}

.pick-item:hover {
  background: var(--bg-hover);
  padding-left: 24px;
}

/* 高分条目左侧高亮色条 */
.pick-item.score-elite {
  border-left: 3px solid #ef4444;
  background: linear-gradient(90deg, rgba(239,68,68,0.03), transparent);
