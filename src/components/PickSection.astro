---
// 每日精选 — 来自 dashboard_v4 的 5 方向 × 5 条推荐
import type { V4DailyData, V4RecommendItem } from '../lib/types';

interface Props {
  data: V4DailyData | null;
}

const { data } = Astro.props;

// 定义方向的显示顺序和图标
const CATEGORY_META: Record<string, { icon: string; desc: string }> = {
  'AI/大模型': { icon: '🤖', desc: 'AI 前沿、大模型、智能体' },
  '数码/硬件': { icon: '📱', desc: '手机、芯片、数码产品' },
  '开源/工具': { icon: '🐙', desc: 'GitHub 开源项目、开发工具' },
  '科技热点': { icon: '🔥', desc: '今日最热的科技话题' },
  '财经/商业': { icon: '📈', desc: '科技财经、商业动态' },
  '财经商业': { icon: '📈', desc: '科技财经、商业动态' },
};

const CATEGORY_ORDER = ['AI/大模型', '数码/硬件', '开源/工具', '科技热点', '财经/商业', '财经商业'];

if (!data || !data.recommendations) return null;

// 统计有数据的分类
const activeCats = CATEGORY_ORDER.filter(cat => (data.recommendations[cat]?.length || 0) > 0);
if (activeCats.length === 0) return null;
---

<section class="pick-section">
  <div class="pick-header">
    <h2 class="pick-title">📊 今日精选推荐</h2>
    <p class="pick-meta">
      来自 {data.total_sources} 个信息源 · 共 {data.total_items} 条
      · 更新于 {data.generated_at}
    </p>
  </div>

  <div class="pick-grid">
    {activeCats.map((cat) => {
      const items = data.recommendations[cat] as V4RecommendItem[];
      const meta = CATEGORY_META[cat] || { icon: '📌', desc: '' };
      return (
        <div class="pick-category">
          <div class="pick-cat-header">
            <span class="pick-cat-icon">{meta.icon}</span>
            <div class="pick-cat-info">
              <h3 class="pick-cat-name">{cat}</h3>
              {meta.desc && <span class="pick-cat-desc">{meta.desc}</span>}
            </div>
            <span class="pick-cat-count">{items.length}条</span>
          </div>

          <div class="pick-items">
            {items.map((item) => (
              <a href={item.url || '#'} target="_blank" rel="noopener" class="pick-item">
                <div class="pick-item-score">{item.score}</div>
                <div class="pick-item-body">
                  <div class="pick-item-title">{item.title}</div>
                  <div class="pick-item-meta">
                    <span class="pick-item-source">{item.source}</span>
                    {item.heat && <span class="pick-item-heat">🔥 {item.heat}</span>}
                  </div>
                  {item.summary && <div class="pick-item-summary">{item.summary}</div>}
                </div>
              </a>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
.pick-section {
  margin-bottom: 28px;
}

.pick-header {
  margin-bottom: 20px;
}

.pick-title {
  font-size: 1.2em;
  font-weight: 800;
  color: var(--text-h);
  margin-bottom: 4px;
}

.pick-meta {
  font-size: 0.75em;
  color: var(--text-m);
}

.pick-grid {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.pick-category {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
  transition: border-color 0.15s;
}

.pick-category:hover {
  border-color: var(--border-hover);
}

.pick-cat-header {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 18px;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
}

.pick-cat-icon {
  font-size: 1.4em;
  flex-shrink: 0;
}

.pick-cat-info {
  flex: 1;
  min-width: 0;
}

.pick-cat-name {
  font-size: 0.9em;
  font-weight: 700;
  color: var(--text-h);
  margin: 0;
}

.pick-cat-desc {
  font-size: 0.72em;
  color: var(--text-m);
}

.pick-cat-count {
  font-family: var(--font-mono);
  font-size: 0.72em;
  font-weight: 600;
  color: var(--accent);
  background: color-mix(in srgb, var(--accent) 10%, transparent);
  padding: 3px 10px;
  border-radius: 6px;
  flex-shrink: 0;
}

.pick-items {
  display: flex;
  flex-direction: column;
}

.pick-item {
  display: flex;
  gap: 12px;
  padding: 12px 18px;
  text-decoration: none;
  border-bottom: 1px solid var(--border);
  transition: background 0.12s;
}

.pick-item:last-child {
  border-bottom: none;
}

.pick-item:hover {
  background: var(--bg-hover);
}

.pick-item-score {
  flex-shrink: 0;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--accent), var(--accent-alt));
  color: #fff;
  border-radius: 8px;
  font-size: 0.7em;
  font-weight: 700;
  font-family: var(--font-mono);
  margin-top: 2px;
}

.pick-item-body {
  flex: 1;
  min-width: 0;
}

.pick-item-title {
  font-size: 0.85em;
  font-weight: 600;
  color: var(--text-h);
  line-height: 1.45;
  margin-bottom: 4px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.pick-item:hover .pick-item-title {
  color: var(--accent);
}

.pick-item-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
  font-size: 0.72em;
  color: var(--text-m);
  margin-bottom: 6px;
}

.pick-item-source {
  color: var(--text-m);
  font-family: var(--font-mono);
  font-size: 0.9em;
}

.pick-item-heat {
  color: #e74c3c;
  font-weight: 600;
}

.pick-item-summary {
  font-size: 0.78em;
  color: var(--text-p);
  line-height: 1.5;
  padding: 6px 10px;
  background: var(--bg);
  border-left: 2px solid var(--accent);
  border-radius: 0 6px 6px 0;
}

/* Light mode */
[data-theme="light"] .pick-category {
  box-shadow: 0 1px 3px rgba(0,0,0,.04);
}
</style>
