  }
  .pick-cat-header {
    padding: 12px 14px;
  }
  .pick-item {
    padding: 10px 14px;
  }
  .pick-item:hover {
    padding-left: 14px;
  }
  .pick-item-score {
    width: 30px;
    height: 30px;
    font-size: 0.65em;
  }
  .pick-masthead {
    flex-direction: column;
    gap: 8px;
  }
}
</style>
