---
// 平台分区列表组件
import type { IntelItem, PlatformMeta } from '../lib/types';
import { getPlatformMeta, SECTION_ORDER, SECTION_CATEGORIES_ZH, SECTION_CATEGORIES_EN } from '../lib/constants';

interface Props {
  grouped: Record<string, IntelItem[]>;
  locale?: 'zh' | 'en';
}

const { grouped, locale = 'zh' } = Astro.props;
const categories = locale === 'zh' ? SECTION_CATEGORIES_ZH : SECTION_CATEGORIES_EN;
const allActiveSections = SECTION_ORDER.filter(s => (grouped[s]?.length || 0) > 0);

if (allActiveSections.length === 0) return null;

// 默认展示前 8 个平台，其余折叠
const DEFAULT_VISIBLE = 8;
const visibleSections = allActiveSections.slice(0, DEFAULT_VISIBLE);
const hiddenSections = allActiveSections.slice(DEFAULT_VISIBLE);
const hasMore = hiddenSections.length > 0;

const showMoreLabel = locale === 'zh' ? `展开更多来源 (${hiddenSections.length})` : `Show ${hiddenSections.length} more sources`;
const showLessLabel = locale === 'zh' ? '收起更多' : 'Show less';
---

<div class="platform-grid">
  {visibleSections.map(sectionKey => {
    const items = grouped[sectionKey];
    // GitHub projects: sort by stars today (hot) descending (trending)
    const displayItems = sectionKey === 'github' ? [...items].sort((a, b) => (b.hot || 0) - (a.hot || 0)) : items;
    const sec = categories[sectionKey] || { name: sectionKey, icon: '📌' };
    const meta = getPlatformMeta(sectionKey, locale);

    return (
      <section class="platform-section" id={`section-${sectionKey}`} style={`--pf-color:${meta.color}`}>
        <div class="section-header">
          <div class="section-title">
            <span>{sec.icon}</span>
            <span style={`color:${meta.color}`}>{sec.name}</span>
            <span class="section-count">{items.length}</span>
          </div>
        </div>
        <div class="news-list">
          {displayItems.map((item, idx) => {
            const hotValue = item.hot || 0;
            const sources = item.merged_sources || [];
            const primarySource = sources[0] || { color: meta.color, icon: meta.icon, label: meta.label };
            const extraSources = sources.slice(1);
            return (
              <div class={`news-item ${item.score >= 7 ? 'score-high' : item.score >= 5 ? 'score-med' : ''}`} style={`--tag-color:${primarySource.color}`}>
                <span class="news-idx">{idx + 1}</span>
                <div class="news-body">
                  <a href={item.url} target="_blank" rel="noopener" class="news-title">{item.title}</a>
                  <div class="news-footer">
                    <div class="source-tags">
                      <span class="platform-tag" style={`--tag-color:${primarySource.color}`}>
                        <span class="tag-icon">{primarySource.icon}</span>
                        {primarySource.label}
                      </span>
                      {extraSources.map((s: any) => (
                        <span class="platform-tag platform-tag-sm" style={`--tag-color:${s.color}`} title={s.label}>
                          <span class="tag-icon">{s.icon}</span>
                        </span>
                      ))}
                      {item.merged_sources && item.merged_sources.length > 0 && <span class="merge-count">+{extraSources.length}</span>}
                    </div>
                    {hotValue > 0 && <span class="news-hot">🔥 {hotValue}</span>}
                    {item.score > 0 && <span class="news-score">{locale === 'zh' ? '信号' : 'Sig'} <strong>{item.score}</strong></span>}
                    {(item.cross_sources || 0) >= 3 && <span class="cross-badge">🌐 {locale === 'zh' ? '多源确认' : 'Confirmed'}</span>}
                    {(item.cross_sources || 0) >= 3 && <span class="cross-badge">🌐 {locale === 'zh' ? '多源确认' : 'Confirmed'}</span>}
                  </div>
                  {item.desc && <div class="news-desc">{item.desc}</div>}
                </div>
              </div>
            );
          })}
        </div>
      </section>
    );
  })}
</div>

{hasMore && (
  <div class="more-sources-wrap">
    <button class="more-sources-btn" id="moreSourcesBtn" data-show-more={showMoreLabel} data-show-less={showLessLabel}>
      {showMoreLabel}
      <span class="more-arrow">▾</span>
    </button>
    <div class="platform-grid hidden-sources" id="hiddenSources">
      {hiddenSections.map(sectionKey => {
        const items = grouped[sectionKey];
        // GitHub projects: sort by stars today (hot) descending (trending)
        const displayItems = sectionKey === 'github' ? [...items].sort((a, b) => (b.hot || 0) - (a.hot || 0)) : items;
        const sec = categories[sectionKey] || { name: sectionKey, icon: '📌' };
        const meta = getPlatformMeta(sectionKey, locale);

        return (
          <section class="platform-section" id={`section-${sectionKey}`} style={`--pf-color:${meta.color}`}>
            <div class="section-header">
              <div class="section-title">
                <span>{sec.icon}</span>
                <span style={`color:${meta.color}`}>{sec.name}</span>
                <span class="section-count">{items.length}</span>
              </div>
            </div>
            <div class="news-list">
              {displayItems.map((item, idx) => {
                const hotValue = item.hot || 0;
                const sources = item.merged_sources || [];
                const primarySource = sources[0] || { color: meta.color, icon: meta.icon, label: meta.label };
                const extraSources = sources.slice(1);
                return (
                  <div class={`news-item ${item.score >= 7 ? 'score-high' : item.score >= 5 ? 'score-med' : ''}`} style={`--tag-color:${primarySource.color}`}>
                    <span class="news-idx">{idx + 1}</span>
                    <div class="news-body">
                      <a href={item.url} target="_blank" rel="noopener" class="news-title">{item.title}</a>
                      <div class="news-footer">
                        <div class="source-tags">
                          <span class="platform-tag" style={`--tag-color:${primarySource.color}`}>
                            <span class="tag-icon">{primarySource.icon}</span>
                            {primarySource.label}
                          </span>
                          {extraSources.map((s: any) => (
                            <span class="platform-tag platform-tag-sm" style={`--tag-color:${s.color}`} title={s.label}>
                              <span class="tag-icon">{s.icon}</span>
                            </span>
                          ))}
                        </div>
                        {hotValue > 0 && <span class="news-hot">🔥 {hotValue}</span>}
                        {item.score > 0 && <span class="news-score">{locale === 'zh' ? '信号' : 'Sig'} <strong>{item.score}</strong></span>}
                    {(item.cross_sources || 0) >= 3 && <span class="cross-badge">🌐 {locale === 'zh' ? '多源确认' : 'Confirmed'}</span>}
                      </div>
                      {item.desc && <div class="news-desc">{item.desc}</div>}
                    </div>
                  </div>
                );
              })}
            </div>
          </section>
        );
      })}
    </div>
  </div>
)}

<style>
.platform-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;
}

@media (min-width: 640px) {
  .platform-grid {
    grid-template-columns: 1fr 1fr;
  }
}

.platform-section {
  display: flex;
  flex-direction: column;
  max-height: 520px;
  overflow: hidden;
  background: linear-gradient(180deg, color-mix(in srgb, var(--pf-color, var(--accent)) 14%, transparent) 0%, color-mix(in srgb, var(--pf-color, var(--accent)) 4%, var(--bg)) 100%);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: var(--radius-lg);
  border: 1px solid color-mix(in srgb, var(--pf-color, var(--border)) 15%, var(--border));
  transition: border-color 0.2s;
}

.platform-section:hover {
  border-color: color-mix(in srgb, var(--pf-color, var(--accent)) 30%, transparent);
}

.platform-section .section-header {
  flex-shrink: 0;
  margin-bottom: 0;
  padding: 14px 16px 0;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12px;
}

.platform-section .section-title {
  font-size: 1.1em;
  font-weight: 700;
  color: var(--text-h);
  display: flex;
  align-items: center;
  gap: 8px;
  letter-spacing: -0.3px;
}

.section-count {
  font-size: 0.72em;
  font-weight: 500;
  color: var(--text-m);
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 2px 10px;
  font-family: var(--font-mono);
  font-variant-numeric: tabular-nums;
}

.platform-section .news-list {
  flex: 1;
  overflow-y: auto;
  min-height: 0;
  border: none;
  border-radius: 0;
  background: transparent;
  display: flex;
  flex-direction: column;
}

.platform-section .news-list::-webkit-scrollbar { width: 4px; }
.platform-section .news-list::-webkit-scrollbar-track { background: transparent; }
.platform-section .news-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
.platform-section .news-list::-webkit-scrollbar-thumb:hover { background: var(--text-m); }
.platform-section .news-list { scrollbar-width: thin; scrollbar-color: var(--border) transparent; }

.news-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 12px 16px;
  border-bottom: 1px solid var(--border);
  border-left: 3px solid color-mix(in srgb, var(--tag-color, transparent) 40%, transparent);
  transition: background 0.15s ease, border-color 0.15s ease;
}

.news-item:last-child { border-bottom: none; }

.news-item:hover {
  background: var(--bg-hover);
  border-left-color: color-mix(in srgb, var(--tag-color, transparent) 70%, transparent);
}

.news-idx {
  font-family: var(--font-mono);
  font-size: 0.65em;
  font-weight: 500;
  color: var(--text-m);
  min-width: 20px;
  padding-top: 3px;
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
  opacity: 0.6;
}

.news-body { flex: 1; min-width: 0; }

.news-title {
  font-size: 0.88em;
  font-weight: 550;
  color: var(--text-h);
  line-height: 1.45;
  display: block;
  transition: color 0.12s ease;
}

.news-item:hover .news-title { color: var(--accent); }

.news-footer {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
  margin-top: 6px;
}

.news-desc {
  font-size: 0.78em;
  color: var(--text-m);
  line-height: 1.4;
  width: 100%;
  margin-top: 4px;
}

.news-hot {
  font-size: 0.72em;
  color: #ef4444;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}

.news-score {
  font-family: var(--font-mono);
  font-size: 0.65em;
  color: var(--text-m);
  font-weight: 500;
  font-variant-numeric: tabular-nums;
}

.news-score strong { color: var(--accent); font-weight: 700; }

.news-item.score-high {
  border-left-color: color-mix(in srgb, var(--tag-color, var(--accent)) 80%, transparent);
  background: linear-gradient(90deg, color-mix(in srgb, var(--tag-color, var(--accent)) 8%, transparent), transparent);
  box-shadow: inset 4px 0 12px color-mix(in srgb, var(--tag-color, var(--accent)) 6%, transparent);
}

.news-item.score-med {
  border-left-color: color-mix(in srgb, var(--tag-color, rgba(251, 191, 36, 0.5)) 55%, transparent);
  background: linear-gradient(90deg, color-mix(in srgb, var(--tag-color, var(--accent)) 3%, transparent), transparent);
}

/* ── Cross-source badge ── */
.cross-badge {
  font-size: 0.62em;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: var(--radius-full);
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.12), rgba(34, 197, 94, 0.06));
  color: #22C55E;
  border: 1px solid rgba(34, 197, 94, 0.2);
  white-space: nowrap;
}

/* ── More Sources Toggle ── */
.more-sources-wrap {
  margin-top: 8px;
  text-align: center;
}

.more-sources-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 28px;
  font-size: 0.82em;
  font-weight: 600;
  color: var(--text-p);
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  cursor: pointer;
  transition: all 0.15s;
  font-family: var(--font-sans);
}

.more-sources-btn:hover {
  border-color: var(--accent);
  color: var(--accent);
  background: var(--accent-glow);
}

.more-arrow {
  font-size: 0.8em;
  transition: transform 0.2s;
}

.more-sources-btn.expanded .more-arrow {
  transform: rotate(180deg);
}

.hidden-sources {
  display: none;
  margin-top: 24px;
}

.hidden-sources.visible {
  display: grid;
}
</style>

{hasMore && (
  <script>
    (function() {
      var btn = document.getElementById('moreSourcesBtn');
      var hidden = document.getElementById('hiddenSources');
      if (btn && hidden) {
        var showMore = btn.getAttribute('data-show-more') || '展开更多';
        var showLess = btn.getAttribute('data-show-less') || '收起';
        btn.addEventListener('click', function() {
          var isVisible = hidden.classList.toggle('visible');
          btn.classList.toggle('expanded', isVisible);
          btn.childNodes[0].textContent = isVisible ? showLess : showMore;
        });
      }
    })();
  </script>
)}
</style>
